---
interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
}

const { 
  title, 
  description = "An On3 scale historical model railroad display dedicated to the memory of the Nevada County Narrow Gauge Railroad. Located at Nevada County Fairgrounds, Grass Valley, CA.",
  image = "/images/bear-river-bridge.jpg",
  type = "website"
} = Astro.props;

const siteUrl = "https://ncngmodelrailroad.org";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);

// Structured data for nonprofit organization (Schema.org)
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "NonprofitOrganization",
  "name": "Nevada County Narrow Gauge Historical Model Railroad",
  "alternateName": "NCNG Historical Model Railroad",
  "url": siteUrl,
  "logo": `${siteUrl}/images/hero-logo.png`,
  "description": description,
  "foundingDate": "1986",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Grass Valley",
    "addressRegion": "CA",
    "addressCountry": "US"
  },
  "areaServed": "Nevada County, California",
  "nonprofitStatus": "501(c)(3)",
  "sameAs": []
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Nevada County Narrow Gauge Historical Model Railroad" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#8B0000" />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={`${siteUrl}${image}`} />
    <meta property="og:site_name" content="NCNG Historical Model Railroad" />
    <meta property="og:locale" content="en_US" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${image}`} />
    
    <!-- Fonts - preconnect for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/images/hero-logo.png" />
    
    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Skip to main content - Accessibility -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-primary text-white px-4 py-2 rounded z-50">
      Skip to main content
    </a>
    <!-- Header -->
    <header class="bg-white shadow-sm sticky top-0 z-50" role="banner">
      <nav class="container py-4" aria-label="Main navigation">
        <div class="flex items-center justify-between">
          <a href="/" class="flex items-center gap-3" aria-label="NCNG Historical Model Railroad - Home">
            <span class="text-xl md:text-2xl font-bold text-primary" style="font-family: 'Archivo Black', serif;">
              N.C.N.G.
            </span>
            <span class="hidden sm:inline text-sm text-gray-600">
              Historical Model Railroad
            </span>
          </a>
          
          <div class="flex items-center gap-6">
            <a href="/gallery" class="text-gray-700 hover:text-primary transition-colors hidden md:inline focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 rounded">
              Gallery
            </a>
            <a href="/events" class="text-gray-700 hover:text-primary transition-colors hidden md:inline focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 rounded">
              Events
            </a>
            <a href="/volunteer" class="text-gray-700 hover:text-primary transition-colors hidden md:inline focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 rounded">
              Volunteer
            </a>
            <a href="/#visit" class="text-gray-700 hover:text-primary transition-colors hidden md:inline focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 rounded">
              Visit
            </a>
            <a href="/#donate" class="btn-primary text-sm py-2 px-4 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2">
              Donate
            </a>
          </div>
        </div>
      </nav>
    </header>

    <!-- Main Content -->
    <main id="main-content" class="flex-grow" role="main">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white py-12" role="contentinfo">
      <div class="container">
        <div class="grid md:grid-cols-3 gap-8">
          <div>
            <h3 class="text-lg font-bold mb-4 text-white">N.C.N.G. Historical Model Railroad</h3>
            <p class="text-gray-400 text-sm">
              A 501(c)(3) non-profit all volunteer organization dedicated to preserving 
              the memory of the Nevada County Narrow Gauge Railroad.
            </p>
          </div>
          
          <div>
            <h3 class="text-lg font-bold mb-4 text-white">Location</h3>
            <address class="text-gray-400 text-sm not-italic">
              Nevada County Fairgrounds<br />
              Grass Valley, California
            </address>
          </div>
          
          <div>
            <h3 class="text-lg font-bold mb-4 text-white">Open During</h3>
            <ul class="text-gray-400 text-sm space-y-1">
              <li>Major fairground events</li>
              <li>Special open houses</li>
              <li>By special arrangement</li>
            </ul>
          </div>
        </div>
        
        <div class="border-t border-gray-800 mt-8 pt-8 text-center text-gray-500 text-sm">
          <p>
            © {new Date().getFullYear()} N.C.N.G. Historical Model Railroad. 
            Incorporated 1986 as the "N.C.N.G. Project"
          </p>
          <p class="mt-2 text-xs">
            Note: The NCNG Historical Model Railroad is a separate non-profit organization 
            not affiliated with other museums or groups.
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

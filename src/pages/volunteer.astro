---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { Icon } from 'astro-icon/components';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const opportunities = [
  { icon: 'solar:tram-bold', title: 'Train Operations', desc: 'Run trains during events and open houses' },
  { icon: 'solar:settings-bold', title: 'Maintenance & Construction', desc: 'Help build and maintain the layout' },
  { icon: 'solar:pallete-2-bold', title: 'Scenery & Detailing', desc: 'Create realistic landscapes and structures' },
  { icon: 'solar:camera-bold', title: 'Photography & Documentation', desc: 'Document our work and history' },
  { icon: 'solar:users-group-rounded-bold', title: 'Visitor Engagement', desc: 'Welcome guests and share railroad history' },
];

const interests = [
  { value: 'operations', label: 'Train Operations' },
  { value: 'maintenance', label: 'Maintenance & Construction' },
  { value: 'scenery', label: 'Scenery & Detailing' },
  { value: 'photography', label: 'Photography' },
  { value: 'visitors', label: 'Visitor Engagement' },
];
---

<BaseLayout title="Volunteer | N.C.N.G. Model Railroad" description="Join our volunteer team at the N.C.N.G. Historical Model Railroad in Grass Valley. Positions in train operations, layout maintenance, scenery building, photography, and visitor engagement.">
  <!-- Hero -->
  <section class="bg-gray-900 text-white py-20">
    <div class="container text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Become a Volunteer</h1>
      <p class="text-lg text-gray-300 max-w-2xl mx-auto">
        Join our dedicated team of volunteers who keep the memory of the Nevada County Narrow Gauge Railroad alive.
      </p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-2xl">

      <div class="bg-cream p-6 rounded-lg mb-8">
        <h2 class="text-xl font-semibold mb-4">Volunteer Opportunities</h2>
        <ul class="space-y-3">
          {opportunities.map(opp => (
            <li class="flex items-start gap-3">
              <Icon name={opp.icon} class="w-6 h-6 text-primary flex-shrink-0 mt-0.5" />
              <div>
                <strong>{opp.title}</strong>
                <p class="text-gray-600 text-sm">{opp.desc}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Detailed Info Sections -->
      <div class="space-y-8 mb-8">
        <div class="bg-amber-50 border-l-4 border-primary p-6 rounded-r-lg">
          <h2 class="text-2xl font-bold text-primary mb-3">Welcome New Members!</h2>
          <p class="text-gray-700 font-semibold mb-2">New Members, Junior Members, Docents, School Teachers Welcome!</p>
          <p class="text-gray-600">Become a part of history! Help your community and share the knowledge of Nevada County's rich railroad heritage with others. The N.C.N.G. Historical Model Railroad — not a club — has opportunities in all shapes and sizes, from layout construction and maintenance to telling the public about our railroad history at open houses.</p>
        </div>

        <div class="bg-white border border-gray-200 p-6 rounded-lg">
          <h3 class="text-xl font-bold text-primary mb-3 flex items-center gap-2"><Icon name="solar:calendar-bold" class="w-5 h-5" /> Work Sessions</h3>
          <p class="text-gray-700 font-medium mb-2">First Saturday and Third Wednesday of the month — Noon to 1pm</p>
          <p class="text-gray-600 mb-3">Come see us at the layout! We meet on the First Saturday and Third Wednesday of the month, Noon to 1pm. Whether you're interested in model railroading or the railroad history of Nevada County, we have something for you!</p>
          <p class="text-sm text-gray-600 italic">Special note – these work sessions are generally canceled whenever there is a paid admission event at the fairgrounds. There may be a parking fee at some free events held at the fairgrounds. Otherwise, park at Gate 1 and enter – the Historical Model Railroad is to the left.</p>
        </div>

        <div class="bg-white border border-gray-200 p-6 rounded-lg">
          <h3 class="text-xl font-bold text-primary mb-3 flex items-center gap-2"><Icon name="solar:microphone-bold" class="w-5 h-5" /> Docents Needed</h3>
          <p class="text-gray-600">Do you like to share with others the history of our county? Are you good at storytelling or talking with the public? During our open houses, docents are needed to help explain the history of the Nevada County Narrow Gauge Railroad. No need to bother with model building — just share the joy of knowing the county's railroad history! We have the information, even if you don't. If history is your passion, become a N.C.N.G. Historical Model Railroad docent.</p>
        </div>

        <div class="bg-white border border-gray-200 p-6 rounded-lg">
          <h3 class="text-xl font-bold text-primary mb-3 flex items-center gap-2"><Icon name="solar:users-group-rounded-bold" class="w-5 h-5" /> Junior Members (Ages 12-18)</h3>
          <p class="text-gray-600">Junior Members Welcomed — A special category for Junior Members (ages 12–18, with an accompanying adult member) is available. Junior members are encouraged to learn the ins and outs of model railroading, as well as the history of the Nevada County Narrow Gauge Railroad. A family adult will need to participate with the junior member.</p>
        </div>

        <div class="bg-white border border-gray-200 p-6 rounded-lg">
          <h3 class="text-xl font-bold text-primary mb-3 flex items-center gap-2"><Icon name="solar:book-bold" class="w-5 h-5" /> School Teachers</h3>
          <p class="text-gray-600">Attention School Teachers! Are you teaching Nevada County history or transportation history and would like to give your students a unique experience? Our museum-quality model of the Nevada County Narrow Gauge Railroad is bound to inspire the imagination of your students. Contact us to make arrangements for your class's own special tour. Tours are generally scheduled well in advance.</p>
        </div>
      </div>

      <form 
        name="volunteer" 
        method="POST" 
        action="https://formspree.io/f/YOUR_FORM_ID"
        class="space-y-6 bg-white border border-gray-200 p-6 rounded-lg"
      >
        <!-- Get free form endpoint at https://formspree.io (50 submissions/month free) -->
        <!-- Or use: action="mailto:info@ncngmodelrailroad.org" for simple email -->
        
        <div>
          <label for="name" class="block text-sm font-medium text-gray-700 mb-1">
            Full Name *
          </label>
          <input 
            type="text" 
            id="name" 
            name="name" 
            required
            class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-primary focus:border-primary"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
            Email Address *
          </label>
          <input 
            type="email" 
            id="email" 
            name="email" 
            required
            class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-primary focus:border-primary"
          />
        </div>

        <div>
          <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">
            Phone (optional)
          </label>
          <input 
            type="tel" 
            id="phone" 
            name="phone"
            class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-primary focus:border-primary"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">
            Areas of Interest
          </label>
          <div class="space-y-2">
            {interests.map(int => (
              <label class="flex items-center gap-2">
                <input type="checkbox" name="interests" value={int.value} class="rounded text-primary" />
                <span>{int.label}</span>
              </label>
            ))}
          </div>
        </div>

        <div>
          <label for="experience" class="block text-sm font-medium text-gray-700 mb-1">
            Tell us about yourself
          </label>
          <textarea 
            id="experience" 
            name="experience" 
            rows="4"
            placeholder="Any model railroad experience? What interests you about N.C.N.G. history?"
            class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-primary focus:border-primary"
          ></textarea>
        </div>

        <Button type="submit" class="w-full py-3">Submit Volunteer Application</Button>
        
        <p class="text-sm text-gray-600 text-center">
          We'll reach out within a week to discuss opportunities.
        </p>
      </form>
    </div>
  </section>
</BaseLayout>

    caption: 'Young visitors enjoying the model railroad at public event',
    category: 'Events'
  },
  {
    src: `${base}/images/gallery-img_9139.jpg`,
    alt: 'Families viewing the detailed model railroad display',
    caption: 'Families viewing the detailed layout display',
    category: 'Events'
  },
  {
    src: `${base}/images/gallery-img_9141.jpg`,
    alt: 'Visitors watching trains at fairgrounds open house event',
    caption: 'Visitors watching trains at fairgrounds open house',
    category: 'Events'
  },
  {
    src: `${base}/images/gallery-img_9711.jpg`,
    alt: 'Miniature western town with detailed buildings and figures',
    caption: 'Miniature western town with detailed buildings and figures',
    category: 'Layout'
  },
  {
    src: `${base}/images/gallery-img_9712.jpg`,
    alt: 'Mountain mining scene with ore cars and headframe',
    caption: 'Mountain mining scene with ore cars and headframe',
    category: 'Layout'
  },
  {
    src: `${base}/images/gallery-img_9713.jpg`,
    alt: 'Sierra Nevada scenery with pine trees and period structures',

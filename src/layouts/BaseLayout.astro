---
interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
  heroImage?: string;
}

const { 
  title, 
  description = "An On3 scale historical model railroad display dedicated to the memory of the Nevada County Narrow Gauge Railroad. Located at Nevada County Fairgrounds, Grass Valley, CA.",
  image = "/images/bear-river-bridge.jpg",
  type = "website",
  heroImage
} = Astro.props;

import { Icon } from 'astro-icon/components';
import { organization } from '../config/organization';
import { navItems } from '../config/navigation';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteUrl = `${Astro.site?.origin || 'https://djdefi.github.io'}${base}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site || 'https://djdefi.github.io');

// Structured data for nonprofit organization (Schema.org)
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "NonprofitOrganization",
  "name": organization.fullName,
  "alternateName": organization.name,
  "url": siteUrl,
  "logo": `${siteUrl}/images/hero-logo.png`,
  "description": description,
  "foundingDate": String(organization.founded),
  "address": {
    "@type": "PostalAddress",
    "streetAddress": organization.location.streetAddress,
    "addressLocality": organization.location.city,
    "addressRegion": organization.location.state,
    "postalCode": organization.location.zip,
    "addressCountry": "US"
  },
  "areaServed": "Nevada County, California",
  "nonprofitStatus": organization.nonprofit,
  "telephone": organization.contact.phone,
  "email": organization.contact.email,
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": organization.contact.phone,
    "contactType": "customer service",
    "areaServed": "Nevada County, CA"
  },
  "sameAs": [organization.social.facebook]
};

// Structured data for local business / museum (Schema.org)
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "Museum",
  "name": organization.name,
  "description": `A historically accurate On3 scale model of the Nevada County Narrow Gauge Railroad, operated by volunteers since ${organization.founded}.`,
  "url": siteUrl,
  "telephone": organization.contact.phone,
  "email": organization.contact.email,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": organization.location.streetAddress,
    "addressLocality": organization.location.city,
    "addressRegion": organization.location.state,
    "postalCode": organization.location.zip,
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": organization.location.geo.latitude,
    "longitude": organization.location.geo.longitude
  },
  "hasMap": organization.location.mapsUrl,
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "description": "Open during Nevada County Fair events, special operating sessions, and by arrangement"
  },
  "priceRange": "Free",
  "sameAs": [organization.social.facebook]
};

// Breadcrumb structured data
const pathSegments = Astro.url.pathname.replace(/\/$/, '').split('/').filter(Boolean);
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": siteUrl
    },
    ...pathSegments.map((segment, index) => ({
      "@type": "ListItem",
      "position": index + 2,
      "name": segment.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' '),
      "item": `${siteUrl}/${segment}`
    }))
  ]
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content={organization.fullName} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#8B0000" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1a1a2e" media="(prefers-color-scheme: dark)" />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={`${siteUrl}${image}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:site_name" content={organization.name} />
    <meta property="og:locale" content="en_US" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${image}`} />
    <meta name="twitter:site" content="@NCNGRailroad" />
    
    <!-- Fonts - preconnect for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="apple-touch-icon" href={`${base}/images/hero-logo.png`} />

    <!-- PWA Manifest -->
    <link rel="manifest" href={`${base}/manifest.json`} />
    {heroImage && <link rel="preload" as="image" href={heroImage} />}
    
    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    {pathSegments.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    )}
    
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Skip to main content - Accessibility -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-primary text-white px-4 py-2 rounded z-50">
      Skip to main content
    </a>
    <!-- Header -->
    <header class="bg-white shadow-sm sticky top-0 z-50" role="banner">
      <nav class="container py-4" aria-label="Main navigation">
        <div class="flex items-center justify-between">
          <a href={`${base}/`} class="flex items-center gap-3" aria-label={`${organization.name} - Home`}>
            <span class="text-xl md:text-2xl font-bold text-primary" style="font-family: 'Archivo Black', serif;">
              {organization.abbreviation}
            </span>
            <span class="hidden sm:inline text-sm text-gray-600">
              Historical Model Railroad
            </span>
          </a>
          
          <!-- Desktop Nav -->
          <div class="hidden md:flex items-center gap-6">
            {navItems.map((item) =>
              item.label === 'Donate' ? (
                <a href={`${base}${item.href}`} class="btn-primary text-sm py-2 px-4 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2">
                  {item.label}
                </a>
              ) : item.icon ? (
                <a href={`${base}${item.href}`} class="text-gray-700 hover:text-primary transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 rounded inline-flex items-center gap-1.5">
                  <Icon name={item.icon} class="w-4 h-4" />
                  {item.label}
                </a>
              ) : (
                <a href={`${base}${item.href}`} class="text-gray-700 hover:text-primary transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 rounded">
                  {item.label}
                </a>
              )
            )}
          </div>
          
          <!-- Mobile Menu Button -->
          <button 
            id="mobile-menu-btn"
            class="md:hidden p-3 text-gray-700 hover:text-primary focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 rounded"
            aria-label="Toggle navigation menu"
            aria-expanded="false"
            aria-controls="mobile-menu"
          >
            <Icon name="solar:hamburger-menu-linear" class="w-6 h-6" />
          </button>
        </div>
      </nav>
      
      <!-- Mobile Menu -->
      <nav 
        id="mobile-menu" 
        class="md:hidden hidden bg-white border-t border-gray-200 shadow-lg"
        aria-label="Mobile navigation"
      >
        <div class="container py-4 flex flex-col gap-2">
          {navItems.map((item) =>
            item.label === 'Donate' ? (
              <a href={`${base}${item.href}`} class="block py-3 px-4 btn-primary text-center rounded-lg">
                {item.label}
              </a>
            ) : item.icon ? (
              <a href={`${base}${item.href}`} class="flex items-center gap-2 py-3 px-4 text-gray-700 hover:bg-gray-50 hover:text-primary rounded-lg transition-colors">
                <Icon name={item.icon} class="w-4 h-4" />
                {item.label}
              </a>
            ) : (
              <a href={`${base}${item.href}`} class="block py-3 px-4 text-gray-700 hover:bg-gray-50 hover:text-primary rounded-lg transition-colors">
                {item.label}
              </a>
            )
          )}
        </div>
      </nav>
    </header>

    <!-- Main Content -->
    <main id="main-content" class="flex-grow" role="main">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white py-12" role="contentinfo">
      <div class="container">
        <div class="track-divider mb-10"></div>
        <div class="grid md:grid-cols-3 gap-8">
          <div>
            <h3 class="text-lg font-bold mb-4 text-white">{organization.name}</h3>
            <p class="text-gray-300 text-sm">
              A {organization.nonprofit} nonprofit all volunteer organization dedicated to preserving 
              the memory of the Nevada County Narrow Gauge Railroad.
            </p>
          </div>
          
          <div>
            <h3 class="text-lg font-bold mb-4 text-white">Location</h3>
            <address class="text-gray-300 text-sm not-italic space-y-3">
              <div class="flex items-start gap-2">
                <Icon name="solar:map-point-bold" class="w-5 h-5 text-gray-500 flex-shrink-0 mt-0.5" />
                <span>{organization.location.venue}<br />{organization.location.streetAddress}<br />{organization.location.city}, {organization.location.state} {organization.location.zip}<br /><br />{organization.location.poBox}<br />{organization.location.poCity}, {organization.location.poState} {organization.location.poZip}</span>
              </div>
              <div class="flex items-center gap-2">
                <Icon name="solar:map-arrow-right-bold" class="w-5 h-5 text-gray-500 flex-shrink-0" />
                <a href={organization.location.mapsUrl} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Get Directions</a>
              </div>
              <div class="flex items-center gap-2">
                <Icon name="solar:phone-bold" class="w-5 h-5 text-gray-500 flex-shrink-0" />
                <a href={organization.contact.phoneHref} class="hover:text-white transition-colors">{organization.contact.phone}</a>
              </div>
              <div class="flex items-center gap-2">
                <Icon name="solar:letter-bold" class="w-5 h-5 text-gray-500 flex-shrink-0" />
                <a href={`mailto:${organization.contact.email}`} class="hover:text-white transition-colors">{organization.contact.email}</a>
              </div>
            </address>
          </div>
          
          <div>
            <h3 class="text-lg font-bold mb-4 text-white">Open During</h3>
            <ul class="text-gray-300 text-sm space-y-2">
              <li class="flex items-center gap-2">
                <Icon name="solar:calendar-bold" class="w-4 h-4 text-gray-500 flex-shrink-0" />
                Major fairground events
              </li>
              <li class="flex items-center gap-2">
                <Icon name="solar:clock-circle-bold" class="w-4 h-4 text-gray-500 flex-shrink-0" />
                Special open houses
              </li>
              <li class="flex items-center gap-2">
                <Icon name="solar:phone-bold" class="w-4 h-4 text-gray-500 flex-shrink-0" />
                By special arrangement
              </li>
            </ul>
            <div class="mt-4">
              <a href={organization.social.facebook} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-gray-300 hover:text-white transition-colors text-sm">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                Follow us on Facebook
              </a>
            </div>
          </div>
        </div>
        
        <div class="border-t border-gray-800 mt-8 pt-8 text-center text-gray-400 text-sm">
          <p>
            © {new Date().getFullYear()} {organization.name}. 
            Incorporated {organization.founded} as the "{organization.abbreviation} Project"
          </p>
          <p class="mt-2 text-xs">
            Note: The {organization.name} is a separate nonprofit organization 
            not affiliated with other museums or groups.
          </p>
        </div>
      </div>
    </footer>

    <!-- Service Worker Registration -->
    <script is:inline>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js');
      }
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<script>
  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  
  if (menuBtn && mobileMenu) {
    menuBtn.addEventListener('click', () => {
      const isExpanded = menuBtn.getAttribute('aria-expanded') === 'true';
      menuBtn.setAttribute('aria-expanded', String(!isExpanded));
      mobileMenu.classList.toggle('hidden');
    });
    
    // Close menu when clicking a link
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        menuBtn.setAttribute('aria-expanded', 'false');
      });
    });
    
    // Close menu on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !mobileMenu.classList.contains('hidden')) {
        mobileMenu.classList.add('hidden');
        menuBtn.setAttribute('aria-expanded', 'false');
        menuBtn.focus();
      }
    });
  }
</script>

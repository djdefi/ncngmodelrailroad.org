---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { Icon } from 'astro-icon/components';

const links = [
  {
    name: 'Nevada County Fairgrounds',
    url: 'https://www.nevadacountyfair.com',
    description: 'Home of the N.C.N.G. Historical Model Railroad. Check for upcoming events and activities.',
  },
  {
    name: 'Nevada County Narrow Gauge Railroad Museum',
    url: 'https://ncngrrmuseum.org',
    description: 'Dedicated to preserving the history of the Nevada County Narrow Gauge Railroad.',
  },
  {
    name: "Swasey's Hardware & Hobbies",
    url: 'https://swaseys.com',
    description: 'Local hobby shop in Grass Valley supporting model railroad enthusiasts.',
  },
  {
    name: 'West Coast Trains',
    url: 'https://westcoasttrains.net',
    description: 'Model railroad supplies and equipment.',
  },
  {
    name: 'National Model Railroad Association (NMRA)',
    url: 'https://www.nmra.org',
    description: 'The world\'s largest organization devoted to the development, promotion, and enjoyment of the hobby of model railroading.',
  },
  {
    name: 'Nevada County Historical Society',
    url: 'https://www.nevadacountyhistory.org',
    description: 'Preserving and sharing the rich history of Nevada County, California.',
  },
  {
    name: 'California State Railroad Museum',
    url: 'https://www.californiarailroad.museum',
    description: 'Sacramento\'s world-class museum celebrating California\'s railroad heritage.',
  },
  {
    name: 'Narrow Gauge Preservation Society',
    url: 'https://www.ngps.org',
    description: 'Dedicated to the preservation and history of narrow gauge railroads across the United States.',
  },
];
---

<BaseLayout
  title="Useful Links & Resources | N.C.N.G. Model Railroad"
  description="Friends, partners, and resources related to the Nevada County Narrow Gauge Railroad. Model railroad suppliers, local organizations, and Nevada County history links."
>
  <!-- Hero -->
  <section class="bg-gray-900 text-white py-16">
    <div class="container text-center">
      <h1 class="text-4xl md:text-5xl font-display font-bold mb-4">Useful Links</h1>
      <p class="text-lg text-gray-300 max-w-2xl mx-auto">
        Friends, partners, and resources related to the Nevada County Narrow Gauge Railroad
      </p>
    </div>
  </section>

  <!-- Links Grid -->
  <section class="py-16 bg-white">
    <div class="container max-w-4xl">
      <p class="text-lg text-gray-600 mb-8 max-w-3xl">
        Explore these organizations, suppliers, and resources connected to narrow gauge railroading and Nevada County heritage.
      </p>
      <div class="grid md:grid-cols-2 gap-6">
        {links.map((link) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="bg-white rounded-xl shadow-sm p-6 border border-gray-200 hover:shadow-md transition-shadow group block"
          >
            <div class="flex items-center justify-between mb-2">
              <h2 class="text-xl font-bold text-primary group-hover:text-primary-light transition-colors">
                {link.name}
              </h2>
              <Icon name="solar:square-arrow-right-up-linear" class="h-5 w-5 text-primary group-hover:text-primary-light transition-colors flex-shrink-0 ml-2" />
            </div>
            <p class="text-gray-600">{link.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

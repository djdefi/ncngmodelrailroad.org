---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { Icon } from 'astro-icon/components';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const donationUses = [
  { icon: 'solar:settings-bold', title: 'Maintenance', desc: 'Keep our locomotives and rolling stock in operating condition' },
  { icon: 'solar:buildings-2-bold', title: 'Layout Expansion', desc: 'Continue building new scenes and improving the layout' },
  { icon: 'solar:lightbulb-bolt-bold', title: 'Equipment', desc: 'Upgrade DCC systems, lighting, and technical equipment' },
  { icon: 'solar:book-bold', title: 'Education', desc: 'Develop educational materials and programs for schools' },
  { icon: 'solar:buildings-bold', title: 'Facility', desc: 'Maintain our building at the Nevada County Fairgrounds' },
];
---

<BaseLayout title="Donate | N.C.N.G. Model Railroad" description="Support the Nevada County Narrow Gauge Historical Model Railroad with a tax-deductible donation. Help preserve California railroad history for future generations.">
  <!-- Hero -->
  <section class="py-20 bg-primary text-white">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-6">
          Support Railroad History
        </h1>
        <p class="text-xl text-gray-200 mb-4">
          Your tax-deductible donation helps us preserve and share the story of the 
          Nevada County Narrow Gauge Railroad with future generations.
        </p>
        <div class="inline-flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full text-sm">
          <Icon name="solar:verified-check-bold" class="w-5 h-5" />
          <span>501(c)(3) Tax-Deductible Organization</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Donation Options -->
  <section class="py-16 bg-white">
    <div class="container max-w-4xl">
      <h2 class="text-3xl font-bold text-center mb-12">Ways to Give</h2>
      
      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <!-- Online Donation -->
        <div class="bg-gray-50 p-8 rounded-2xl border border-gray-200">
          <div class="mb-4"><Icon name="solar:card-bold" class="w-10 h-10 text-primary" /></div>
          <h3 class="text-xl font-bold mb-3">Donate Online</h3>
          <p class="text-gray-600 mb-6">
            Make a secure donation online. Credit cards, debit cards, and bank transfers accepted.
          </p>
          <form action="https://www.paypal.com/donate" method="post" target="_blank">
            <input type="hidden" name="business" value="info@ncngmodelrailroad.org" />
            <input type="hidden" name="item_name" value="N.C.N.G. Historical Model Railroad Donation" />
            <input type="hidden" name="currency_code" value="USD" />
            <button type="submit" class="btn-primary w-full py-3 text-center flex items-center justify-center gap-2">
              <img src="https://www.paypalobjects.com/webstatic/icon/pp258.png" alt="PayPal" class="h-5" />
              Donate with PayPal
            </button>
          </form>
          <p class="text-xs text-gray-600 mt-3 text-center">
            Secure payment via PayPal. Credit and debit cards accepted.
          </p>
        </div>

        <!-- Mail Donation -->
        <div class="bg-gray-50 p-8 rounded-2xl border border-gray-200">
          <div class="mb-4"><Icon name="solar:letter-bold" class="w-10 h-10 text-primary" /></div>
          <h3 class="text-xl font-bold mb-3">Donate by Mail</h3>
          <p class="text-gray-600 mb-4">
            Send a check made payable to:
          </p>
          <div class="bg-white p-4 rounded-lg border border-gray-200 mb-4">
            <p class="font-mono text-sm">
              N.C.N.G. Historical Model Railroad<br />
              c/o Nevada County Fairgrounds<br />
              Grass Valley, CA
            </p>
          </div>
          <p class="text-sm text-gray-600">
            You'll receive a tax receipt for your records.
          </p>
        </div>
      </div>

      <!-- In-Kind Donations -->
      <div class="bg-amber-50 p-8 rounded-2xl border border-amber-200 text-center">
        <div class="mb-4"><Icon name="solar:tram-bold" class="w-10 h-10 text-primary" /></div>
        <h3 class="text-xl font-bold mb-3">In-Kind Donations</h3>
        <p class="text-gray-700 mb-4">
          We also accept donations of model railroad equipment, tools, materials, 
          and railroad memorabilia. Contact us to discuss what you'd like to donate.
        </p>
        <a href="mailto:info@ncngmodelrailroad.org" class="text-primary hover:underline font-medium">
          info@ncngmodelrailroad.org
        </a>
      </div>
    </div>
  </section>

  <!-- How Donations Help -->
  <section class="py-16 bg-gray-50">
    <div class="container max-w-4xl">
      <h2 class="text-3xl font-bold text-center mb-4">How Your Donation Helps</h2>
      <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
        As an all-volunteer organization, 100% of your donation goes directly to 
        preserving and improving the layout.
      </p>
      
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {donationUses.map(use => (
          <div class="bg-white p-6 rounded-xl shadow-sm">
            <div class="mb-3"><Icon name={use.icon} class="w-8 h-8 text-primary" /></div>
            <h3 class="font-bold mb-2">{use.title}</h3>
            <p class="text-gray-600 text-sm">{use.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Corporate Matching -->
  <section class="py-16 bg-white">
    <div class="container max-w-3xl text-center">
      <h2 class="text-3xl font-bold mb-4">Corporate Matching</h2>
      <p class="text-gray-600 mb-6">
        Many employers match charitable donations made by their employees. 
        Check with your HR department to see if your company offers a matching 
        gift program—you could double your impact!
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-gray-900 text-white">
    <div class="container text-center max-w-2xl">
      <h2 class="text-3xl font-bold mb-4">Every Donation Makes a Difference</h2>
      <p class="text-gray-300 mb-8">
        Whether $10 or $1,000, your support helps us continue our mission of 
        preserving Nevada County railroad history.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <Button href={`${base}/volunteer`} variant="outline" class="border-white text-white hover:bg-white hover:text-gray-900">
          Volunteer Instead
        </Button>
        <Button href={`${base}/about`} variant="outline" class="border-white text-white hover:bg-white hover:text-gray-900">
          Learn More About Us
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>

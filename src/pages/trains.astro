---
import BaseLayout from '../layouts/BaseLayout.astro';
import PhotoCard from '../components/PhotoCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const trainEntries = await getCollection('trains');
const galleryEntries = await getCollection('gallery');

function getGalleryPhoto(id: string) {
  const entry = galleryEntries.find((galleryEntry) => {
    const imageBase = galleryEntry.data.image.replace(/\.[^.]+$/, '');

    return (
      galleryEntry.id === id ||
      galleryEntry.id.toLowerCase() === id.toLowerCase() ||
      imageBase === id ||
      imageBase.toLowerCase() === id.toLowerCase()
    );
  });

  if (!entry) {
    throw new Error(`Missing gallery photo: ${id}`);
  }

  return {
    src: `${base}/images/${entry.data.image}`,
    alt: entry.data.title,
    caption: entry.data.caption,
  };
}

const engines = trainEntries
  .sort((a, b) => a.data.order - b.data.order)
  .map(entry => ({
    number: entry.data.number,
    wheel: entry.data.wheel,
    name: entry.data.name,
    source: entry.data.source,
    rosterEntry: entry.data.rosterEntry,
    notes: entry.data.notes,
  }));

const historyPhoto = getGalleryPhoto('historic-locomotive');
const rosterPhotos = [
  getGalleryPhoto('engine8-freight'),
  getGalleryPhoto('trestle-bridge-approach'),
  getGalleryPhoto('gallery-img-9712'),
];
const otherPowerPhoto = getGalleryPhoto('gallery-img-9713');
const scenePhotos = [
  getGalleryPhoto('trestle-bridge-wide'),
  getGalleryPhoto('gallery-img-7760'),
  getGalleryPhoto('gallery-DSC07756'),
  getGalleryPhoto('gallery-DSC07773'),
];

const historyHighlights = [
  { label: 'Construction started', value: 'February 11, 1875' },
  { label: 'Last spike driven', value: 'May 20, 1876' },
  { label: 'Oil conversion complete', value: 'By 1916' },
  { label: 'Final steam addition', value: 'Engine #8 in 1933' },
];

const rosterHighlights = [
  {
    icon: 'solar:tram-bold',
    title: 'Original Baldwin engines',
    text: 'Engines #1, #2, and #3 formed the road\'s early Baldwin-built core.',
  },
  {
    icon: 'solar:history-bold',
    title: 'Later acquisitions',
    text: 'Additional power came from the Lake Tahoe Railroad, Southern Pacific, and Denver & Rio Grande.',
  },
  {
    icon: 'solar:lightbulb-bolt-bold',
    title: 'Fuel change',
    text: 'The first locomotives were wood burners, and all N.C.N.G. engines had been converted to oil by 1916.',
  },
  {
    icon: 'solar:box-bold',
    title: 'Working railroad',
    text: 'The roster handled passenger service, freight, mining supplies, and interchange traffic at Colfax.',
  },
];
---

<BaseLayout title="Trains | N.C.N.G. Model Railroad" description="History of the Nevada County Narrow Gauge Railroad, its locomotive roster, and train scenes on the layout." image="/images/engine8-hero.jpg" heroImage={`${base}/images/engine8-hero.jpg`}>
  <!-- Hero with Engine #8 photo -->
  <section class="relative py-28 md:py-36 text-white overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img 
        src={`${base}/images/engine8-hero.jpg`}
        alt="Engine #8 model on the N.C.N.G. layout" 
        class="w-full h-full object-cover"
        loading="eager"
        decoding="async"
        fetchpriority="high"
        width={1920}
        height={1080}
      />
      <div class="absolute inset-0 bg-gradient-to-r from-gray-900/85 via-gray-900/50 to-transparent"></div>
    </div>
    <div class="container relative z-10">
      <div class="max-w-3xl">
        <span class="text-sm uppercase tracking-widest text-gray-300 font-medium">The Trains</span>
        <h1 class="text-4xl md:text-5xl font-bold mt-4 mb-6">Trains of the Nevada County Narrow Gauge</h1>
        <p class="text-xl text-gray-200">
          From Colfax through Chicago Park and Grass Valley to Nevada City, the line carried freight,
          passengers, mail, and mining supplies for 66 years.
        </p>
      </div>
    </div>
  </section>

  <!-- History -->
  <section class="py-16 bg-white">
    <div class="container max-w-5xl">
      <SectionHeader eyebrow="Railroad History" title="From Colfax to Nevada City" />
      <div class="grid md:grid-cols-5 gap-10 items-start">
        <div class="md:col-span-3 space-y-5 text-gray-700 leading-relaxed">
          <p>
            The Nevada County Narrow Gauge Railroad ran from the Central Pacific depot at Colfax through
            Chicago Park and Grass Valley to Nevada City. Before the railroad, moving passengers and heavy
            mining equipment over county roads could take most of the day and became much harder in winter.
          </p>
          <p>
            Construction began on February 11, 1875, and the last spike was driven on May 20, 1876.
            Over the next 66 years, the line carried freight, passengers, mail, and supplies between
            Nevada County and the mainline connection at Colfax.
          </p>
          <p>
            The railroad earned the nickname "Never Come, Never Go," but its engine roster steadily grew.
            The first three locomotives were Baldwin wood burners, later additions came from other roads,
            and by 1916 all N.C.N.G. engines had been converted to oil.
          </p>
        </div>
        <div class="md:col-span-2 space-y-4">
          <PhotoCard src={historyPhoto.src} alt={historyPhoto.alt} caption={historyPhoto.caption} aspectRatio="4/3" />
          <div class="grid grid-cols-2 gap-4">
            {historyHighlights.map((highlight) => (
              <div class="rounded-xl bg-cream p-4">
                <p class="text-xs font-semibold uppercase tracking-wide text-primary">{highlight.label}</p>
                <p class="mt-2 text-sm text-gray-700">{highlight.value}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="track-divider"></div>

  <!-- Engine Roster - Card-based -->
  <section class="py-16 bg-cream">
    <div class="container max-w-5xl">
      <SectionHeader eyebrow="Motive Power" title="Engine Roster" description="Original Baldwin locomotives, later acquisitions, and the engines represented on the layout." />

      <!-- Photo showcase -->
      <div class="grid md:grid-cols-3 gap-4 mb-12">
        <PhotoCard src={rosterPhotos[0].src} alt={rosterPhotos[0].alt} caption={rosterPhotos[0].caption} class="md:col-span-2" />
        <div class="grid gap-4">
          <PhotoCard src={rosterPhotos[1].src} alt={rosterPhotos[1].alt} caption={rosterPhotos[1].caption} />
          <PhotoCard src={rosterPhotos[2].src} alt={rosterPhotos[2].alt} caption={rosterPhotos[2].caption} />
        </div>
      </div>

      <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-4 mb-12">
        {rosterHighlights.map((highlight) => (
          <div class="rounded-xl bg-white p-5 shadow-sm">
            <Icon name={highlight.icon} class="mb-3 h-6 w-6 text-primary" />
            <h3 class="mb-2 text-lg font-bold">{highlight.title}</h3>
            <p class="text-sm leading-relaxed text-gray-600">{highlight.text}</p>
          </div>
        ))}
      </div>

      <!-- Engine cards -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {engines.map((engine) => (
          <div class="bg-white rounded-xl shadow-sm p-5 border-l-4 border-primary hover:shadow-md transition-shadow">
            <div class="flex items-baseline justify-between mb-2">
              <span class="text-2xl font-bold text-primary">{engine.number}</span>
              <span class="font-mono text-xs bg-gray-100 px-2 py-1 rounded text-gray-700">{engine.wheel}</span>
            </div>
            {engine.name !== '—' && (
              <p class="italic text-secondary font-medium mb-2">"{engine.name}"</p>
            )}
            {(engine.source || engine.rosterEntry) && (
              <ul class="mb-3 space-y-1 text-xs text-gray-600">
                {engine.source && (
                  <li><span class="font-semibold text-gray-900">Source:</span> {engine.source}</li>
                )}
                {engine.rosterEntry && (
                  <li><span class="font-semibold text-gray-900">Roster:</span> {engine.rosterEntry}</li>
                )}
              </ul>
            )}
            <p class="text-gray-600 text-sm leading-relaxed">{engine.notes}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Additional Motive Power -->
  <section class="py-16 bg-white">
    <div class="container max-w-5xl">
      <SectionHeader eyebrow="Other Equipment" title="Gas &amp; Standard Gauge Power" description="The N.C.N.G. story also includes gas mechanical switchers and standard gauge power working out of Colfax." />
      <div class="grid md:grid-cols-5 gap-8 items-start">
        <div class="md:col-span-3 space-y-5 text-gray-700 leading-relaxed">
          <p>
            The N.C.N.G. also rostered two gas mechanical switchers: #10, a 0-4-0 Plymouth acquired
            in 1936 and later wrecked, and #11, a 0-4-0 Whitcomb.
          </p>
          <p>
            Standard gauge power appeared around 1913 on dual gauge track from Colfax to the Bear River
            gravel spur, where a two-truck Heisler and a two-truck Climax handled the work.
          </p>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <Icon name="solar:tram-bold" class="mt-0.5 h-5 w-5 flex-shrink-0 text-primary" />
              <span><strong>#10 Plymouth</strong> - 0-4-0 gas mechanical, acquired in 1936</span>
            </li>
            <li class="flex items-start gap-3">
              <Icon name="solar:tram-bold" class="mt-0.5 h-5 w-5 flex-shrink-0 text-primary" />
              <span><strong>#11 Whitcomb</strong> - 0-4-0 gas mechanical switcher</span>
            </li>
            <li class="flex items-start gap-3">
              <Icon name="solar:history-bold" class="mt-0.5 h-5 w-5 flex-shrink-0 text-primary" />
              <span><strong>Heisler and Climax</strong> - standard gauge power used on the Bear River gravel spur</span>
            </li>
          </ul>
        </div>
        <div class="md:col-span-2">
          <PhotoCard src={otherPowerPhoto.src} alt={otherPowerPhoto.alt} caption={otherPowerPhoto.caption} aspectRatio="4/3" />
        </div>
      </div>
    </div>
  </section>

  <!-- Model Photos -->
  <section class="py-16 bg-gray-50">
    <div class="container max-w-5xl">
      <SectionHeader eyebrow="Scenes Along the Line" title="Train Views on the Layout" description="A few of the train and line scenes that appear across the railroad." />
      <div class="grid md:grid-cols-2 gap-6">
        {scenePhotos.map((photo) => (
          <PhotoCard src={photo.src} alt={photo.alt} caption={photo.caption} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

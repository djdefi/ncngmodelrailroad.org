---
interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
  heroImage?: string;
}

const { 
  title, 
  description = "An On3 scale historical model railroad display dedicated to the memory of the Nevada County Narrow Gauge Railroad. Located at Nevada County Fairgrounds, Grass Valley, CA.",
  image = "/images/bear-river-bridge.jpg",
  type = "website",
  heroImage
} = Astro.props;

import { Icon } from 'astro-icon/components';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteUrl = `${Astro.site?.origin || 'https://djdefi.github.io'}${base}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site || 'https://djdefi.github.io');

// Structured data for nonprofit organization (Schema.org)
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "NonprofitOrganization",
  "name": "Nevada County Narrow Gauge Historical Model Railroad",
  "alternateName": "N.C.N.G. Historical Model Railroad",
  "url": siteUrl,
  "logo": `${siteUrl}/images/hero-logo.png`,
  "description": description,
  "foundingDate": "1986",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Grass Valley",
    "addressRegion": "CA",
    "addressCountry": "US"
  },
  "areaServed": "Nevada County, California",
  "nonprofitStatus": "501(c)(3)",
  "telephone": "(916) 871-6341",
  "email": "info@ncngmodelrailroad.org",
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "(916) 871-6341",
    "contactType": "customer service",
    "areaServed": "Nevada County, CA"
  },
  "sameAs": ["https://www.facebook.com/NCNGHistoricalModelRailroad/"]
};

// Structured data for local business / museum (Schema.org)
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "Museum",
  "name": "N.C.N.G. Historical Model Railroad",
  "description": "A historically accurate On3 scale model of the Nevada County Narrow Gauge Railroad, operated by volunteers since 1986.",
  "url": siteUrl,
  "telephone": "(916) 871-6341",
  "email": "info@ncngmodelrailroad.org",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Nevada County Fairgrounds",
    "addressLocality": "Grass Valley",
    "addressRegion": "CA",
    "postalCode": "95949",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 39.2191,
    "longitude": -121.0601
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "description": "Open during Nevada County Fair events, special operating sessions, and by arrangement"
  },
  "priceRange": "Free",
  "sameAs": ["https://www.facebook.com/NCNGHistoricalModelRailroad/"]
};

// Breadcrumb structured data
const pathSegments = Astro.url.pathname.replace(/\/$/, '').split('/').filter(Boolean);
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": siteUrl
    },
    ...pathSegments.filter(seg => seg !== 'ncngmodelrailroad.org').map((segment, index) => ({
      "@type": "ListItem",
      "position": index + 2,
      "name": segment.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' '),
      "item": `${siteUrl}/${segment}`
    }))
  ]
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Nevada County Narrow Gauge Historical Model Railroad" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#8B0000" />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={`${siteUrl}${image}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:site_name" content="N.C.N.G. Historical Model Railroad" />
    <meta property="og:locale" content="en_US" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${image}`} />
    <meta name="twitter:site" content="@NCNGRailroad" />
    
    <!-- Fonts - preconnect for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="apple-touch-icon" href={`${base}/images/hero-logo.png`} />
    {heroImage && <link rel="preload" as="image" href={heroImage} />}
    
    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    {pathSegments.filter(seg => seg !== 'ncngmodelrailroad.org').length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    )}
    
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Skip to main content - Accessibility -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-primary text-white px-4 py-2 rounded z-50">
      Skip to main content
    </a>
    <!-- Header -->
    <header class="bg-white shadow-sm sticky top-0 z-50" role="banner">
      <nav class="container py-4" aria-label="Main navigation">
        <div class="flex items-center justify-between">
          <a href={`${base}/`} class="flex items-center gap-3" aria-label="N.C.N.G. Historical Model Railroad - Home">
            <span class="text-xl md:text-2xl font-bold text-primary" style="font-family: 'Archivo Black', serif;">
              N.C.N.G.
            </span>
            <span class="hidden sm:inline text-sm text-gray-600">
              Historical Model Railroad
            </span>
          </a>
          
          <!-- Desktop Nav -->
          <div class="hidden md:flex items-center gap-6">
            <a href={`${base}/about`} class="text-gray-700 hover:text-primary transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 rounded">
              About
            </a>
            <a href={`${base}/gallery`} class="text-gray-700 hover:text-primary transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 rounded inline-flex items-center gap-1.5">
              <Icon name="solar:camera-bold" class="w-4 h-4" />
              Gallery
            </a>
            <a href={`${base}/events`} class="text-gray-700 hover:text-primary transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 rounded inline-flex items-center gap-1.5">
              <Icon name="solar:calendar-bold" class="w-4 h-4" />
              Events
            </a>
            <a href={`${base}/trains`} class="text-gray-700 hover:text-primary transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 rounded inline-flex items-center gap-1.5">
              <Icon name="solar:tram-bold" class="w-4 h-4" />
              Trains
            </a>
            <a href={`${base}/board-members`} class="text-gray-700 hover:text-primary transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 rounded">
              Board
            </a>
            <a href={`${base}/links`} class="text-gray-700 hover:text-primary transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 rounded">
              Links
            </a>
            <a href={`${base}/contact`} class="text-gray-700 hover:text-primary transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 rounded">
              Contact
            </a>
            <a href={`${base}/volunteer`} class="text-gray-700 hover:text-primary transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 rounded">
              Volunteer
            </a>
            <a href={`${base}/donate`} class="btn-primary text-sm py-2 px-4 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2">
              Donate
            </a>
          </div>
          
          <!-- Mobile Menu Button -->
          <button 
            id="mobile-menu-btn"
            class="md:hidden p-3 text-gray-700 hover:text-primary focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 rounded"
            aria-label="Toggle navigation menu"
            aria-expanded="false"
            aria-controls="mobile-menu"
          >
            <Icon name="solar:hamburger-menu-linear" class="w-6 h-6" />
          </button>
        </div>
      </nav>
      
      <!-- Mobile Menu -->
      <div 
        id="mobile-menu" 
        class="md:hidden hidden bg-white border-t border-gray-200 shadow-lg"
        role="menu"
      >
        <div class="container py-4 flex flex-col gap-2">
          <a href={`${base}/about`} class="block py-3 px-4 text-gray-700 hover:bg-gray-50 hover:text-primary rounded-lg transition-colors" role="menuitem">
            About
          </a>
          <a href={`${base}/gallery`} class="flex items-center gap-2 py-3 px-4 text-gray-700 hover:bg-gray-50 hover:text-primary rounded-lg transition-colors" role="menuitem">
            <Icon name="solar:camera-bold" class="w-4 h-4" />
            Gallery
          </a>
          <a href={`${base}/events`} class="flex items-center gap-2 py-3 px-4 text-gray-700 hover:bg-gray-50 hover:text-primary rounded-lg transition-colors" role="menuitem">
            <Icon name="solar:calendar-bold" class="w-4 h-4" />
            Events
          </a>
          <a href={`${base}/trains`} class="flex items-center gap-2 py-3 px-4 text-gray-700 hover:bg-gray-50 hover:text-primary rounded-lg transition-colors" role="menuitem">
            <Icon name="solar:tram-bold" class="w-4 h-4" />
            Trains
          </a>
          <a href={`${base}/board-members`} class="block py-3 px-4 text-gray-700 hover:bg-gray-50 hover:text-primary rounded-lg transition-colors" role="menuitem">
            Board
          </a>
          <a href={`${base}/links`} class="block py-3 px-4 text-gray-700 hover:bg-gray-50 hover:text-primary rounded-lg transition-colors" role="menuitem">
            Links
          </a>
          <a href={`${base}/contact`} class="block py-3 px-4 text-gray-700 hover:bg-gray-50 hover:text-primary rounded-lg transition-colors" role="menuitem">
            Contact
          </a>
          <a href={`${base}/volunteer`} class="block py-3 px-4 text-gray-700 hover:bg-gray-50 hover:text-primary rounded-lg transition-colors" role="menuitem">
            Volunteer
          </a>
          <a href={`${base}/donate`} class="block py-3 px-4 btn-primary text-center rounded-lg" role="menuitem">
            Donate
          </a>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main id="main-content" class="flex-grow" role="main">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white py-12" role="contentinfo">
      <div class="container">
        <div class="track-divider mb-10"></div>
        <div class="grid md:grid-cols-3 gap-8">
          <div>
            <h3 class="text-lg font-bold mb-4 text-white">N.C.N.G. Historical Model Railroad</h3>
            <p class="text-gray-300 text-sm">
              A 501(c)(3) nonprofit all volunteer organization dedicated to preserving 
              the memory of the Nevada County Narrow Gauge Railroad.
            </p>
          </div>
          
          <div>
            <h3 class="text-lg font-bold mb-4 text-white">Location</h3>
            <address class="text-gray-300 text-sm not-italic space-y-3">
              <div class="flex items-start gap-2">
                <Icon name="solar:map-point-bold" class="w-5 h-5 text-gray-500 flex-shrink-0 mt-0.5" />
                <span>Nevada County Fairgrounds<br />Grass Valley, California<br /><br />P.O. Box 2258<br />Nevada City, CA 95959</span>
              </div>
              <div class="flex items-center gap-2">
                <Icon name="solar:phone-bold" class="w-5 h-5 text-gray-500 flex-shrink-0" />
                <a href="tel:9168716341" class="hover:text-white transition-colors">(916) 871-6341</a>
              </div>
              <div class="flex items-center gap-2">
                <Icon name="solar:letter-bold" class="w-5 h-5 text-gray-500 flex-shrink-0" />
                <a href="mailto:info@ncngmodelrailroad.org" class="hover:text-white transition-colors">info@ncngmodelrailroad.org</a>
              </div>
            </address>
          </div>
          
          <div>
            <h3 class="text-lg font-bold mb-4 text-white">Open During</h3>
            <ul class="text-gray-300 text-sm space-y-2">
              <li class="flex items-center gap-2">
                <Icon name="solar:calendar-bold" class="w-4 h-4 text-gray-500 flex-shrink-0" />
                Major fairground events
              </li>
              <li class="flex items-center gap-2">
                <Icon name="solar:clock-circle-bold" class="w-4 h-4 text-gray-500 flex-shrink-0" />
                Special open houses
              </li>
              <li class="flex items-center gap-2">
                <Icon name="solar:phone-bold" class="w-4 h-4 text-gray-500 flex-shrink-0" />
                By special arrangement
              </li>
            </ul>
            <div class="mt-4">
              <a href="https://www.facebook.com/NCNGHistoricalModelRailroad/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-gray-300 hover:text-white transition-colors text-sm">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                Follow us on Facebook
              </a>
            </div>
          </div>
        </div>
        
        <div class="border-t border-gray-800 mt-8 pt-8 text-center text-gray-400 text-sm">
          <p>
            © {new Date().getFullYear()} N.C.N.G. Historical Model Railroad. 
            Incorporated 1986 as the "N.C.N.G. Project"
          </p>
          <p class="mt-2 text-xs">
            Note: The N.C.N.G. Historical Model Railroad is a separate nonprofit organization 
            not affiliated with other museums or groups.
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<script>
  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  
  if (menuBtn && mobileMenu) {
    menuBtn.addEventListener('click', () => {
      const isExpanded = menuBtn.getAttribute('aria-expanded') === 'true';
      menuBtn.setAttribute('aria-expanded', String(!isExpanded));
      mobileMenu.classList.toggle('hidden');
    });
    
    // Close menu when clicking a link
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        menuBtn.setAttribute('aria-expanded', 'false');
      });
    });
    
    // Close menu on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !mobileMenu.classList.contains('hidden')) {
        mobileMenu.classList.add('hidden');
        menuBtn.setAttribute('aria-expanded', 'false');
        menuBtn.focus();
      }
    });
  }
</script>

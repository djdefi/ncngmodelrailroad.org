---
interface Props {
  name: 'arrow-right' | 'check' | 'location' | 'ticket' | 'users' | 'chevron-down' | 'search-plus' | 'close' | 'chevron-left' | 'chevron-right';
  class?: string;
  size?: 'sm' | 'md' | 'lg';
}

const { name, class: className = '', size = 'md' } = Astro.props;

const sizes = {
  sm: 'w-4 h-4',
  md: 'w-5 h-5',
  lg: 'w-6 h-6'
};

const icons: Record<string, string> = {
  'arrow-right': 'M17 8l4 4m0 0l-4 4m4-4H3',
  'check': 'M5 13l4 4L19 7',
  'location': 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
  'ticket': 'M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z',
  'users': 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z',
  'chevron-down': 'M19 9l-7 7-7-7',
  'search-plus': 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7',
  'close': 'M6 18L18 6M6 6l12 12',
  'chevron-left': 'M15 19l-7-7 7-7',
  'chevron-right': 'M9 5l7 7-7 7'
};
---

<svg 
  class={`${sizes[size]} ${className}`} 
  fill="none" 
  stroke="currentColor" 
  viewBox="0 0 24 24"
  aria-hidden="true"
>
  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icons[name]}></path>
</svg>

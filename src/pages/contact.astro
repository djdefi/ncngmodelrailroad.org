---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { Icon } from 'astro-icon/components';
import { organization } from '../config/organization';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Contact Us | N.C.N.G. Model Railroad" description="Get in touch with the Nevada County Narrow Gauge Historical Model Railroad. Send us a message or visit us in person." image="/images/building-exterior.jpg" heroImage={`${base}/images/building-exterior.jpg`}>
  <!-- Hero with building exterior -->
  <section class="relative py-20 text-white overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img 
        src={`${base}/images/building-exterior.jpg`} 
        alt="N.C.N.G. Historical Model Railroad building at Nevada County Fairgrounds" 
        class="w-full h-full object-cover"
        loading="eager"
        decoding="async"
        fetchpriority="high"
        width={1440}
        height={1920}
      />
      <div class="absolute inset-0 bg-gray-900/65"></div>
    </div>
    <div class="container relative z-10">
      <div class="max-w-3xl">
        <span class="text-sm uppercase tracking-widest text-gray-300 font-medium">Get In Touch</span>
        <h1 class="text-4xl md:text-5xl font-bold mt-4 mb-6">Contact Us</h1>
        <p class="text-xl text-gray-200">Drop us a line!</p>
      </div>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Left: Contact Form -->
        <div>
          <SectionHeader title="Send Us a Message" />
          <form
            name="contact"
            method="POST"
            enctype="text/plain"
            action={`mailto:${organization.contact.email}`}
            class="space-y-6 bg-white border border-gray-200 p-6 rounded-lg"
          >
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-1">
                Name
              </label>
              <input
                type="text"
                id="name"
                name="name"
                class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-primary focus:border-primary"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
                Email *
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-primary focus:border-primary"
              />
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-1">
                Message
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                placeholder="How can we help you?"
                class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-primary focus:border-primary"
              ></textarea>
            </div>

            <button type="submit" class="btn-primary w-full py-3">Send</button>

            <p class="text-sm text-gray-600 text-center">
              We'll get back to you as soon as possible.
            </p>
          </form>
        </div>

        <!-- Right: Info & Visit -->
        <div class="space-y-8">
          <div>
            <SectionHeader title="Visit the Layout" />
            <p class="text-gray-600">
              The best way to understand the layout is to see it running in person during an event, open house, or arranged visit.
            </p>
          </div>

          <div class="bg-cream p-6 rounded-lg">
            <h3 class="text-xl font-bold text-primary mb-4">{organization.fullName}</h3>

            <div class="space-y-4 text-gray-700">
              <div class="flex items-start gap-3">
                <Icon name="solar:map-point-bold" class="w-6 h-6 text-primary flex-shrink-0 mt-0.5" />
                <div>
                  <strong class="block">Address</strong>
                  <p>{organization.location.venue}<br />{organization.location.streetAddress}<br />{organization.location.city}, {organization.location.state} {organization.location.zip}</p>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <Icon name="solar:letter-bold" class="w-6 h-6 text-primary flex-shrink-0 mt-0.5" />
                <div>
                  <strong class="block">Mailing Address</strong>
                  <p>{organization.location.poBox}<br />{organization.location.poCity}, {organization.location.poState} {organization.location.poZip}</p>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <Icon name="solar:phone-bold" class="w-6 h-6 text-primary flex-shrink-0 mt-0.5" />
                <div>
                  <strong class="block">Phone</strong>
                  <a href={organization.contact.phoneHref} class="text-primary hover:underline">{organization.contact.phone}</a>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <Icon name="solar:letter-bold" class="w-6 h-6 text-primary flex-shrink-0 mt-0.5" />
                <div>
                  <strong class="block">Email</strong>
                  <a href={`mailto:${organization.contact.email}`} class="text-primary hover:underline">{organization.contact.email}</a>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <Icon name="solar:clock-circle-bold" class="w-6 h-6 text-primary flex-shrink-0 mt-0.5" />
                <div>
                  <strong class="block">Hours</strong>
                  <p>Posted events, work sessions, and arranged visits</p>
                </div>
              </div>
            </div>
          </div>

          <a
            href={organization.location.mapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary w-full py-3 text-center inline-block"
          >
            <span class="inline-flex items-center gap-2">
              <Icon name="solar:map-arrow-right-bold" class="w-5 h-5" />
              Get Directions
            </span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <SectionHeader
        title="Find Us"
        description="We're located inside the Nevada County Fairgrounds in Grass Valley, California."
        centered
      />
      <div class="rounded-lg overflow-hidden shadow-lg border border-gray-200">
        <iframe
          src={`https://maps.google.com/maps?q=${organization.location.geo.latitude},${organization.location.geo.longitude}&z=15&output=embed`}
          width="100%"
          height="400"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Nevada County Fairgrounds location map"
        ></iframe>
      </div>
      <div class="mt-4 text-center">
        <a
          href={organization.location.mapsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-primary hover:underline font-medium"
        >
          <Icon name="solar:map-arrow-right-bold" class="w-5 h-5" />
          Open in Google Maps
        </a>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <SectionHeader
        title="Get Involved"
        description="Interested in helping out? See volunteer opportunities or upcoming public events."
        centered
      />
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={`${base}/volunteer`} class="btn-primary px-8 py-3">Become a Volunteer</a>
        <a href={`${base}/events`} class="btn-outline px-8 py-3">Upcoming Events</a>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';
import { organization } from '../config/organization';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const volunteerPhotoIds = ['gallery-img-7238', 'gallery-img-7040', 'gallery-img-7041', 'gallery-img-9141'];
const galleryEntries = await getCollection('gallery');
const volunteerPhotos = volunteerPhotoIds.flatMap((id) => {
  const entry = galleryEntries.find((galleryEntry) => galleryEntry.id === id);
  return entry
    ? [{
        src: `${base}/images/${entry.data.image}`,
        alt: entry.data.title,
        caption: entry.data.caption,
      }]
    : [];
});

const opportunities = [
  { icon: 'solar:tram-bold', title: 'Train Operations', desc: 'Run trains during events and open houses' },
  { icon: 'solar:settings-bold', title: 'Maintenance & Construction', desc: 'Help build and maintain the layout' },
  { icon: 'solar:pallete-2-bold', title: 'Scenery & Detailing', desc: 'Create realistic landscapes and structures' },
  { icon: 'solar:camera-bold', title: 'Photography & Documentation', desc: 'Document our work and history' },
  { icon: 'solar:users-group-rounded-bold', title: 'Docents & Visitor Engagement', desc: 'Welcome guests, answer questions, and interpret railroad history' },
];

const interests = [
  { value: 'operations', label: 'Train Operations' },
  { value: 'maintenance', label: 'Maintenance & Construction' },
  { value: 'scenery', label: 'Scenery & Detailing' },
  { value: 'photography', label: 'Photography' },
  { value: 'docents', label: 'Docents & Visitor Engagement' },
];
---

<BaseLayout title="Volunteer | N.C.N.G. Model Railroad" description="Volunteer with the N.C.N.G. Historical Model Railroad in Grass Valley. Help with operations, maintenance, scenery, photography, and visitor engagement.">
  <!-- Hero -->
  <section class="bg-gray-900 text-white py-20">
    <div class="container text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Become a Volunteer</h1>
      <p class="text-lg text-gray-300 max-w-2xl mx-auto">
        Join the volunteers who operate trains, maintain scenery, work on structures and wiring, and talk with visitors.
      </p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-2xl">

      <div class="bg-cream p-6 rounded-lg mb-8">
        <h2 class="text-xl font-semibold mb-4">Volunteer Opportunities</h2>
        <ul class="space-y-3">
          {opportunities.map(opp => (
            <li class="flex items-start gap-3">
              <Icon name={opp.icon} class="w-6 h-6 text-primary flex-shrink-0 mt-0.5" />
              <div>
                <strong>{opp.title}</strong>
                <p class="text-gray-600 text-sm">{opp.desc}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <div class="mb-10">
        <h2 class="text-2xl font-bold text-primary mb-3">Volunteers at Work</h2>
        <p class="text-gray-600 mb-5">
          A few scenes from construction, scenery work, and day-to-day upkeep on the layout.
        </p>
        <div class="grid sm:grid-cols-2 gap-4">
          {volunteerPhotos.map((photo, index) => (
            <figure class={`overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm ${index === 0 ? 'sm:col-span-2' : ''}`}>
              <img
                src={photo.src}
                alt={photo.alt}
                class={`w-full object-cover ${index === 0 ? 'aspect-[16/9]' : 'aspect-[4/3]'}`}
                loading="lazy"
                decoding="async"
                width={index === 0 ? 1200 : 800}
                height={index === 0 ? 675 : 600}
              />
              <figcaption class="px-4 py-3 text-sm text-gray-600">
                {photo.caption}
              </figcaption>
            </figure>
          ))}
        </div>
      </div>

      <!-- Detailed Info Sections -->
      <div class="space-y-8 mb-8">
        <div class="bg-amber-50 border-l-4 border-primary p-6 rounded-r-lg">
          <h2 class="text-2xl font-bold text-primary mb-3">New Members Welcome</h2>
          <p class="text-gray-700 font-semibold mb-2">Members, junior members, docents, and teachers are all welcome.</p>
          <p class="text-gray-600">There is useful work to do whether you like train operations, scenery, carpentry, wiring, research, photography, or talking with visitors during open houses.</p>
        </div>

        <div class="bg-white border border-gray-200 p-6 rounded-lg">
          <h3 class="text-xl font-bold text-primary mb-3 flex items-center gap-2"><Icon name="solar:calendar-bold" class="w-5 h-5" /> Work Sessions</h3>
          <p class="text-gray-700 font-medium mb-2">First Saturday and Third Wednesday of the month — usually 11 AM to 2 PM</p>
          <p class="text-gray-600 mb-3">We usually meet at the layout on the first Saturday and third Wednesday of the month from 11 AM to 2 PM. Stop by, introduce yourself, and see what kind of work is underway.</p>
          <p class="text-sm text-gray-600 italic">These sessions are usually canceled during paid-admission fairground events. Some free fairground events may still charge for parking. Otherwise, park at Gate 1 and enter; the Historical Model Railroad is to the left.</p>
        </div>

        <div class="bg-white border border-gray-200 p-6 rounded-lg">
          <h3 class="text-xl font-bold text-primary mb-3 flex items-center gap-2"><Icon name="solar:microphone-bold" class="w-5 h-5" /> Docents Needed</h3>
          <p class="text-gray-600">Docents help greet visitors and explain the history of the railroad and the layout during open houses. If you like talking with the public and sharing local history, this is a good place to help.</p>
        </div>

        <div class="bg-white border border-gray-200 p-6 rounded-lg">
          <h3 class="text-xl font-bold text-primary mb-3 flex items-center gap-2"><Icon name="solar:users-group-rounded-bold" class="w-5 h-5" /> Junior Members (Ages 12-18)</h3>
          <p class="text-gray-600">Junior members ages 12 to 18 are welcome with an accompanying adult member. It is a good way to learn model railroading, layout work, and local railroad history together.</p>
        </div>

        <div class="bg-white border border-gray-200 p-6 rounded-lg">
          <h3 class="text-xl font-bold text-primary mb-3 flex items-center gap-2"><Icon name="solar:book-bold" class="w-5 h-5" /> School Teachers</h3>
          <p class="text-gray-600">Teachers covering Nevada County history or transportation history can contact us about class visits. Tours are usually scheduled well in advance.</p>
        </div>
      </div>

      <form 
        name="volunteer" 
        method="POST" 
        enctype="text/plain"
        action={`mailto:${organization.contact.email}`}
        class="space-y-6 bg-white border border-gray-200 p-6 rounded-lg"
      >
        
        <div>
          <label for="name" class="block text-sm font-medium text-gray-700 mb-1">
            Full Name *
          </label>
          <input 
            type="text" 
            id="name" 
            name="name" 
            required
            class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-primary focus:border-primary"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
            Email Address *
          </label>
          <input 
            type="email" 
            id="email" 
            name="email" 
            required
            class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-primary focus:border-primary"
          />
        </div>

        <div>
          <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">
            Phone (optional)
          </label>
          <input 
            type="tel" 
            id="phone" 
            name="phone"
            class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-primary focus:border-primary"
          />
        </div>

        <fieldset>
          <legend class="block text-sm font-medium text-gray-700 mb-2">
            Areas of Interest
          </legend>
          <div class="space-y-2">
            {interests.map(int => (
              <label class="flex items-center gap-2">
                <input type="checkbox" name="interests" value={int.value} class="rounded text-primary" />
                <span>{int.label}</span>
              </label>
            ))}
          </div>
        </fieldset>

        <div>
          <label for="experience" class="block text-sm font-medium text-gray-700 mb-1">
            Tell us about yourself
          </label>
          <textarea 
            id="experience" 
            name="experience" 
            rows="4"
            placeholder="Any model railroad experience? What interests you about N.C.N.G. history?"
            class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-primary focus:border-primary"
          ></textarea>
        </div>

        <Button type="submit" class="w-full py-3">Submit Volunteer Application</Button>
        
        <p class="text-sm text-gray-600 text-center">
          We'll reach out within a week to discuss opportunities.
        </p>
      </form>
    </div>
  </section>
</BaseLayout>

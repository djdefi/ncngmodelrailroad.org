---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const photos = [
  // Original images from existing site
  {
    src: `${base}/images/bear-river-bridge.jpg`,
    alt: 'Historic Bear River Bridge on the N.C.N.G. Railroad line',
    caption: 'Bear River Bridge - One of the most iconic structures on the original N.C.N.G. line',
    category: 'Historic'
  },
  {
    src: `${base}/images/ncng-layout-1.jpg`,
    alt: 'Overhead view of N.C.N.G. layout town scene with buildings, track, and mountain backdrop',
    caption: 'Town scene overview with buildings, track, and painted Sierra backdrop',
    category: 'Layout'
  },
  {
    src: `${base}/images/ncng-layout-2.jpg`,
    alt: 'N.C.N.G. layout scene showing town buildings and track from a different angle',
    caption: 'Town buildings and trackside scenery on our On3 scale layout',
    category: 'Layout'
  },
  {
    src: `${base}/images/historic-locomotive.jpg`,
    alt: 'Historic N.C.N.G. locomotive photograph from the early 1900s',
    caption: 'Original N.C.N.G. locomotive, circa 1900',
    category: 'Historic'
  },
  // New gallery photos - accurately captioned
  {
    src: `${base}/images/gallery-img_7040.jpg`,
    alt: 'Volunteer working on layout structures at a workbench',
    caption: 'Volunteer crafting miniature structures for the layout',
    category: 'Layout'
  },
  {
    src: `${base}/images/gallery-img_7041.jpg`,
    alt: 'Vintage Shell gasoline station scene with period trucks',
    caption: 'Vintage Shell gasoline station scene with period delivery trucks',
    category: 'Layout'
  },
  {
    src: `${base}/images/gallery-img_7238.jpg`,
    alt: 'Volunteers constructing layout at Nevada County Fairgrounds',
    caption: 'Volunteers constructing the layout at Nevada County Fairgrounds',
    category: 'Events'
  },
  {
    src: `${base}/images/gallery-img_7239.jpg`,
    alt: 'N.C.N.G. building exterior at the Nevada County Fairgrounds',
    caption: 'N.C.N.G. building at the Nevada County Fairgrounds',
    category: 'Historic'
  },
  {
    src: `${base}/images/gallery-img_7760.jpg`,
    alt: 'Steam locomotive pulling freight through town scene with buildings and mountain backdrop',
    caption: 'Steam locomotive hauling freight through town — horse-drawn wagon and picket fence in view',
    category: 'Layout'
  },
  {
    src: `${base}/images/gallery-img_7761.jpg`,
    alt: 'Steam locomotive traversing mountain trestle with scenic backdrop',
    caption: 'Steam locomotive traversing mountain trestle bridge',
    category: 'Layout'
  },
  {
    src: `${base}/images/gallery-img_9138.jpg`,
    alt: 'Overhead layout view showing buildings, track, and rolling stock with mountain backdrop',
    caption: 'Layout overview — buildings, rolling stock, and painted mountain scenery',
    category: 'Layout'
  },
  {
    src: `${base}/images/gallery-img_9139.jpg`,
    alt: 'Wide view of the N.C.N.G. layout with town buildings and track',
    caption: 'Wide-angle view of the layout with town scene and trackwork',
    category: 'Layout'
  },
  {
    src: `${base}/images/gallery-img_9141.jpg`,
    alt: 'Layout scene showing trains and scenery details',
    caption: 'Trains and scenery on the N.C.N.G. layout',
    category: 'Layout'
  },
  {
    src: `${base}/images/gallery-img_9711.jpg`,
    alt: 'Detailed town scene with Colfax depot, Christmas tree lot, horse-drawn wagon, and railroad crossing',
    caption: 'Colfax depot area — Christmas tree lot, horse-drawn wagon, and railroad crossing details',
    category: 'Layout'
  },
  {
    src: `${base}/images/gallery-img_9712.jpg`,
    alt: 'Mountain mining scene with ore cars and headframe',
    caption: 'Mountain mining scene with ore cars and headframe',
    category: 'Layout'
  },
  {
    src: `${base}/images/gallery-img_9713.jpg`,
    alt: 'Sierra Nevada scenery with pine trees and period structures',
    caption: 'Sierra Nevada scenery with pines and period structures',
    category: 'Layout'
  },
  {
    src: `${base}/images/gallery-img_9714.jpg`,
    alt: 'Steam train passing through western town scene',
    caption: 'Steam train passing through western town scene',
    category: 'Layout'
  },
  {
    src: `${base}/images/gallery-DSC07725.jpg`,
    alt: 'Mountain hillside scene with structures and tracks on the layout',
    caption: 'Mountain hillside scene with structures and trackwork',
    category: 'Layout'
  },
  {
    src: `${base}/images/gallery-DSC07756.jpg`,
    alt: 'Close-up of model railroad rolling stock',
    caption: 'Rolling stock detail on the N.C.N.G. layout',
    category: 'Layout'
  },
  {
    src: `${base}/images/gallery-DSC07773.jpg`,
    alt: 'Model railroad town scene with period buildings',
    caption: 'Period-accurate town buildings and scenery',
    category: 'Layout'
  },
  {
    src: `${base}/images/gallery-DSC07865.jpg`,
    alt: 'Wide view of the model railroad layout',
    caption: 'Wide view of the N.C.N.G. model railroad',
    category: 'Layout'
  },
  // Trestle bridge video stills
  {
    src: `${base}/images/trestle-bridge-freight.jpg`,
    alt: 'Freight train crossing the Bear River Bridge trestle with tank cars and boxcars',
    caption: 'Freight train crossing the Bear River Bridge trestle — RPM Motor Oil and Shell tank cars',
    category: 'Layout'
  },
  {
    src: `${base}/images/trestle-bridge-wide.jpg`,
    alt: 'Wide view of locomotive and freight consist on the Bear River Bridge model',
    caption: 'Full train on the Bear River Bridge — the signature piece of the layout',
    category: 'Layout'
  },
  {
    src: `${base}/images/trestle-bridge-approach.jpg`,
    alt: 'Locomotive approaching the Bear River Bridge trestle through mountain scenery',
    caption: 'Engine approaching the trestle through the Sierra Nevada foothills',
    category: 'Layout'
  },
  // Building exterior
  {
    src: `${base}/images/building-exterior.jpg`,
    alt: 'N.C.N.G. Historical Model Railroad building at Nevada County Fairgrounds with Railroad Crossing sign',
    caption: 'Our home at the Nevada County Fairgrounds — Historical Exhibit Open!',
    category: 'Events'
  },
  // Engine #8 hero shots
  {
    src: `${base}/images/engine8-hero.jpg`,
    alt: 'Engine #8 approaching on tracks with switches and scenery detail',
    caption: 'Engine #8 approaching the yard — beautiful detail and depth of field',
    category: 'Layout'
  },
  {
    src: `${base}/images/engine8-freight.jpg`,
    alt: 'Engine #8 hauling freight cars past the yard',
    caption: 'Engine #8 hauling a mixed freight consist',
    category: 'Layout'
  },
];

const categories = [...new Set(photos.map(p => p.category))];
---

<BaseLayout title="Photo Gallery - N.C.N.G. Historical Model Railroad" description="Browse our collection of historic photographs and detailed On3 scale model railroad images from the Nevada County Narrow Gauge Historical Model Railroad at the Nevada County Fairgrounds." image="/images/trestle-bridge-wide.jpg">
  <!-- Hero Section -->
  <section class="relative py-20 md:py-28 bg-gray-900 text-white overflow-hidden">
    <div class="absolute inset-0 opacity-30">
      <img 
        src={`${base}/images/ncng-layout-1.jpg`} 
        alt="N.C.N.G. Model Railroad layout" 
        class="w-full h-full object-cover"
        loading="eager"
        decoding="async"
        fetchpriority="high"
        width={550}
        height={320}
      />
    </div>
    <div class="container relative z-10">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">Photo Gallery</h1>
        <p class="text-xl text-gray-300">
          Explore our collection of historic photographs and images from our meticulously 
          crafted On3 scale model railroad layout.
        </p>
      </div>
    </div>
  </section>

  <!-- Category Filter -->
  <section class="py-6 bg-white border-b sticky top-0 z-30">
    <div class="container">
      <div class="flex flex-wrap gap-3 justify-center">
        <button class="category-btn active" data-category="all" aria-pressed="true">All Photos</button>
        {categories.map(cat => (
          <button class="category-btn" data-category={cat.toLowerCase()} aria-pressed="false">{cat}</button>
        ))}
      </div>
    </div>
  </section>

  <!-- Photo Grid -->
  <section class="py-12 bg-gray-50">
    <div class="container">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" id="photo-grid">
        {photos.map((photo, index) => (
          <article 
            class="photo-card group cursor-pointer" 
            data-category={photo.category.toLowerCase()}
            data-index={index}
            tabindex="0"
            role="button"
            aria-label={`View photo: ${photo.alt}`}
          >
            <div class="relative aspect-[4/3] overflow-hidden rounded-xl shadow-lg">
              <img 
                src={photo.src} 
                alt={photo.alt}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                loading="lazy"
                decoding="async"
                width={600}
                height={450}
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                <div class="absolute bottom-0 left-0 right-0 p-4">
                  <span class="inline-block bg-primary text-white text-xs font-semibold px-2 py-1 rounded mb-2">
                    {photo.category}
                  </span>
                  <p class="text-white text-sm">{photo.caption}</p>
                </div>
              </div>
              <button class="absolute top-3 right-3 w-10 h-10 bg-white/90 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity" aria-label="View full size">
                <Icon name="solar:magnifer-bold" class="w-5 h-5 text-gray-700" />
              </button>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Add Photos CTA -->
  <section class="py-16 bg-white">
    <div class="container">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-bold mb-4">Have Photos to Share?</h2>
        <p class="text-gray-600 mb-6">
          If you have historic photos of the Nevada County Narrow Gauge Railroad or photos 
          from your visits to our layout, we'd love to add them to our collection.
        </p>
        <a href="mailto:info@ncngmodelrailroad.org" class="btn-primary">
          Contact Us
        </a>
      </div>
    </div>
  </section>

  <!-- Lightbox Modal -->
  <div id="lightbox" class="fixed inset-0 z-50 hidden bg-black/95 items-center justify-center" role="dialog" aria-modal="true" aria-label="Photo lightbox">
    <button id="lightbox-close" class="absolute top-4 right-4 text-white p-2 hover:bg-white/10 rounded-lg z-10" aria-label="Close lightbox">
      <Icon name="solar:close-square-bold" class="w-8 h-8" />
    </button>
    <button id="lightbox-prev" class="absolute left-4 top-1/2 -translate-y-1/2 text-white p-2 hover:bg-white/10 rounded-lg z-10" aria-label="Previous photo">
      <Icon name="solar:alt-arrow-left-bold" class="w-8 h-8" />
    </button>
    <button id="lightbox-next" class="absolute right-4 top-1/2 -translate-y-1/2 text-white p-2 hover:bg-white/10 rounded-lg z-10" aria-label="Next photo">
      <Icon name="solar:alt-arrow-right-bold" class="w-8 h-8" />
    </button>
    <div class="flex flex-col items-center max-w-5xl w-full px-4">
      <img id="lightbox-img" src="" alt="" class="max-h-[80vh] max-w-full object-contain" />
      <p id="lightbox-caption" class="text-white text-center mt-4 max-w-2xl"></p>
    </div>
  </div>
</BaseLayout>

<style>
  .category-btn {
    display: inline-block;
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    border: 1px solid #d1d5db;
    color: #4b5563;
    font-weight: 500;
    font-size: 0.875rem;
    transition: all 0.2s;
  }
  .category-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }
  .category-btn.active {
    background-color: var(--color-primary);
    border-color: var(--color-primary);
    color: white;
  }
  .photo-card.hidden {
    display: none;
  }
  /* Skip rendering off-screen gallery items until scrolled into view */
  .photo-card:nth-child(n+7) {
    content-visibility: auto;
    contain-intrinsic-size: auto 300px;
  }
</style>

<script>
  // Category filtering
  const categoryBtns = document.querySelectorAll('.category-btn');
  const photoCards = document.querySelectorAll('.photo-card');

  categoryBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const category = btn.getAttribute('data-category');
      
      categoryBtns.forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-pressed', 'true');
      
      photoCards.forEach(card => {
        if (category === 'all' || card.getAttribute('data-category') === category) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });

  // Lightbox functionality
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxCaption = document.getElementById('lightbox-caption');
  const lightboxClose = document.getElementById('lightbox-close');
  const lightboxPrev = document.getElementById('lightbox-prev');
  const lightboxNext = document.getElementById('lightbox-next');
  
  let currentIndex = 0;
  const photos = Array.from(photoCards);

  let triggerElement: HTMLElement | null = null;

  function openLightbox(index: number) {
    currentIndex = index;
    const card = photos[index];
    const img = card.querySelector('img') as HTMLImageElement;
    const caption = card.querySelector('p')?.textContent || '';
    
    triggerElement = document.activeElement as HTMLElement;
    lightboxImg.src = img.src;
    lightboxImg.alt = img.alt;
    if (lightboxCaption) lightboxCaption.textContent = caption;
    
    lightbox?.classList.remove('hidden');
    lightbox?.classList.add('flex');
    document.body.style.overflow = 'hidden';
    lightboxClose?.focus();
  }

  function closeLightbox() {
    lightbox?.classList.add('hidden');
    lightbox?.classList.remove('flex');
    document.body.style.overflow = '';
    triggerElement?.focus();
    triggerElement = null;
  }

  function nextPhoto() {
    const visiblePhotos = photos.filter(p => !p.classList.contains('hidden'));
    const currentVisible = visiblePhotos.indexOf(photos[currentIndex]);
    const nextVisible = (currentVisible + 1) % visiblePhotos.length;
    currentIndex = photos.indexOf(visiblePhotos[nextVisible]);
    openLightbox(currentIndex);
  }

  function prevPhoto() {
    const visiblePhotos = photos.filter(p => !p.classList.contains('hidden'));
    const currentVisible = visiblePhotos.indexOf(photos[currentIndex]);
    const prevVisible = (currentVisible - 1 + visiblePhotos.length) % visiblePhotos.length;
    currentIndex = photos.indexOf(visiblePhotos[prevVisible]);
    openLightbox(currentIndex);
  }

  photoCards.forEach((card, index) => {
    card.addEventListener('click', () => openLightbox(index));
    card.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        openLightbox(index);
      }
    });
  });

  lightboxClose?.addEventListener('click', closeLightbox);
  lightboxNext?.addEventListener('click', nextPhoto);
  lightboxPrev?.addEventListener('click', prevPhoto);

  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  document.addEventListener('keydown', (e) => {
    if (!lightbox?.classList.contains('hidden')) {
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowRight') nextPhoto();
      if (e.key === 'ArrowLeft') prevPhoto();
      // Trap focus within lightbox
      if (e.key === 'Tab') {
        const focusable = lightbox.querySelectorAll<HTMLElement>('button');
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    }
  });
</script>

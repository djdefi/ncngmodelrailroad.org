---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { Icon } from 'astro-icon/components';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const boardMembers = [
  { role: 'President', name: 'Steve Coffey', image: 'board/steve-coffey.jpeg' },
  { role: 'Vice President', name: 'Barry Wright', image: 'board/barry-wright.jpeg' },
  { role: 'Board Member', name: 'Doug Doane', image: null },
  { role: 'Secretary', name: 'Andrew Langdon', image: 'board/andrew-langdon.jpeg' },
  { role: 'Treasurer', name: 'Tarry Nelson', image: 'board/tarry-nelson.jpeg' },
];

function getInitials(name: string) {
  return name.split(' ').map(n => n[0]).join('');
}
---

<BaseLayout
  title="Board Members"
  description="Meet the dedicated board members and volunteers who keep the NCNG Historical Model Railroad running."
>
  <!-- Hero -->
  <section class="bg-gray-900 text-white py-20">
    <div class="container text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Board Members &amp; Leadership</h1>
      <p class="text-lg text-gray-300 max-w-2xl mx-auto">
        Meet the dedicated volunteers who keep our railroad on track.
      </p>
    </div>
  </section>

  <!-- Board Members Grid -->
  <section class="py-16 bg-cream">
    <div class="container max-w-4xl">
      <SectionHeader
        eyebrow="Our Team"
        title="Club Leadership"
        description="These volunteers generously donate their time and expertise to preserve Nevada County railroad history."
        centered
      />

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mt-8">
        {boardMembers.map((member) => (
          <div class="bg-white rounded-xl shadow-sm p-6 text-center hover:shadow-md transition-shadow">
            {member.image ? (
              <div class="w-24 h-24 mx-auto mb-4 rounded-full overflow-hidden shadow-md ring-2 ring-primary/20">
                <img 
                  src={`${base}/images/${member.image}`}
                  alt={`${member.name}, ${member.role}`}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
            ) : (
              <div class="w-24 h-24 mx-auto mb-4 rounded-full bg-primary/10 flex items-center justify-center ring-2 ring-primary/20">
                <span class="text-2xl font-bold text-primary">{getInitials(member.name)}</span>
              </div>
            )}
            <p class="text-primary font-semibold uppercase tracking-wider text-xs">{member.role}</p>
            <p class="text-xl font-bold mt-1">{member.name}</p>
          </div>
        ))}
      </div>

      <div class="mt-12 text-center">
        <p class="text-sm text-gray-500">
          Website maintained by Ryan T.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-white">
    <div class="container max-w-2xl text-center">
      <SectionHeader
        eyebrow="Get Involved"
        title="Interested in Joining?"
        description="We're always looking for new volunteers who share a passion for preserving Nevada County railroad history."
        centered
      />
      <a href={`${base}/volunteer`} class="btn btn-primary inline-flex items-center gap-2">
        <Icon name="solar:users-group-rounded-bold" class="w-5 h-5" />
        Join Our Team
      </a>
    </div>
  </section>
</BaseLayout>

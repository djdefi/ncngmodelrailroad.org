---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { Icon } from 'astro-icon/components';
import { getCollection, render } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const events = await getCollection('events');
const sortedEvents = events.sort((a, b) => 
  new Date(a.data.date).getTime() - new Date(b.data.date).getTime()
);
const upcomingEvents = sortedEvents.filter(e => new Date(e.data.date) >= new Date());
const pastEvents = sortedEvents.filter(e => new Date(e.data.date) < new Date()).reverse();

const siteUrl = Astro.site?.origin || 'https://ncngmodelrailroad.org';

const eventSchemaItems = upcomingEvents.map((event) => ({
  "@context": "https://schema.org",
  "@type": "Event",
  "name": event.data.title,
  "description": event.data.description || event.data.title,
  "startDate": event.data.date.toISOString().split('T')[0],
  "endDate": (event.data.endDate || event.data.date).toISOString().split('T')[0],
  "eventStatus": "https://schema.org/EventScheduled",
  "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
  "location": {
    "@type": "Place",
    "name": event.data.location,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Grass Valley",
      "addressRegion": "CA",
      "addressCountry": "US",
    },
  },
  "organizer": {
    "@type": "Organization",
    "name": "N.C.N.G. Historical Model Railroad",
    "url": siteUrl,
  },
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
  },
}));

const eventSchemaJson = JSON.stringify(eventSchemaItems);

function formatDate(date: Date, endDate?: Date) {
  const options: Intl.DateTimeFormatOptions = { 
    weekday: 'long', 
    year: 'numeric', 
    month: 'long', 
    day: 'numeric' 
  };
  const start = date.toLocaleDateString('en-US', options);
  if (endDate) {
    const end = endDate.toLocaleDateString('en-US', options);
    return `${start} - ${end}`;
  }
  return start;
}
---

<BaseLayout title="Events | N.C.N.G. Model Railroad" description="Upcoming events and operating sessions at the Nevada County Narrow Gauge Historical Model Railroad" image="/images/building-exterior.jpg">
  {eventSchemaItems.length > 0 && (
    <script type="application/ld+json" set:html={eventSchemaJson} />
  )}
  <!-- Hero -->
  <section class="bg-gray-900 text-white py-20">
    <div class="container text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Upcoming Events</h1>
      <p class="text-lg text-gray-300 max-w-2xl mx-auto">
        Posted events, regular work sessions, open houses, and community events at the Nevada County Fairgrounds.
      </p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="mb-10 rounded-2xl border border-amber-200 bg-amber-50 p-6 md:p-8">
        <div class="flex items-start gap-4">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary/10">
            <Icon name="solar:settings-bold" class="w-6 h-6 text-primary" />
          </div>
          <div>
            <p class="mb-2 text-sm font-semibold uppercase tracking-wider text-primary">Regular Work Sessions</p>
            <h2 class="mb-3 text-2xl font-display text-gray-900">Usually the first Saturday and third Wednesday, 11 AM to 2 PM</h2>
            <p class="text-gray-700">
              Work sessions are a good time to meet volunteers, see what is being built or repaired, and ask about helping out.
              They may shift or be canceled during paid-admission fairground events, so check ahead if you are making a special trip.
            </p>
          </div>
        </div>
      </div>
      
      {upcomingEvents.length > 0 ? (
        <div class="space-y-8">
          {upcomingEvents.map(async (event) => {
            const { Content } = await render(event);
            return (
              <article class="card p-6 border-l-4 border-primary">
                <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
                  <div>
                    <h2 class="text-2xl font-display text-gray-900">{event.data.title}</h2>
                    <p class="text-primary font-medium mt-1">
                      {formatDate(event.data.date, event.data.endDate)}
                    </p>
                  </div>
                  {event.data.featured && (
                    <span class="bg-gold text-gray-900 px-3 py-1 rounded-full text-sm font-medium">
                      Featured
                    </span>
                  )}
                </div>
                <p class="text-gray-600 mb-2">
                  <Icon name="solar:map-point-bold" class="w-4 h-4 inline-block mr-1" />
                  {event.data.location}
                </p>
                <div class="prose prose-sm mt-4">
                  <Content />
                </div>
              </article>
            );
          })}
        </div>
      ) : (
        <p class="text-gray-600">No upcoming events scheduled. Check back soon!</p>
      )}
    </div>
  </section>

  {pastEvents.length > 0 && (
    <section class="py-16 bg-cream">
      <div class="container mx-auto px-4 max-w-4xl">
        <h2 class="text-3xl font-display text-gray-900 mb-8">Past Events</h2>
        <div class="space-y-4">
          {pastEvents.slice(0, 5).map((event) => (
            <div class="bg-white p-4 rounded shadow-sm">
              <h3 class="font-semibold text-gray-900">{event.data.title}</h3>
              <p class="text-sm text-gray-600">{formatDate(event.data.date, event.data.endDate)}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="py-16 bg-primary text-white text-center">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-display mb-4">Want to Get Involved?</h2>
      <p class="text-xl mb-8 text-gray-200">We&apos;re always looking for volunteers to help with events, work sessions, and operations.</p>
      <Button href={`${base}/volunteer`} variant="white">Become a Volunteer</Button>
    </div>
  </section>
</BaseLayout>

---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  aspectRatio?: 'video' | 'square' | '4/3';
  overlay?: boolean;
  class?: string;
}

const { 
  src, 
  alt, 
  caption,
  aspectRatio = 'video',
  overlay = true,
  class: className = ''
} = Astro.props;

const aspectClasses = {
  'video': 'aspect-video',
  'square': 'aspect-square',
  '4/3': 'aspect-[4/3]'
};
---

<div class={`relative ${aspectClasses[aspectRatio]} overflow-hidden rounded-xl shadow-lg group ${className}`}>
  <img 
    src={src} 
    alt={alt}
    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
    loading="lazy"
  />
  {overlay && caption && (
    <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/70 to-transparent p-4 md:p-6">
      <p class="text-white text-sm">{caption}</p>
    </div>
  )}
</div>

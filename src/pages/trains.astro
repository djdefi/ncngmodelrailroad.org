---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { Icon } from 'astro-icon/components';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const engines = [
  { number: '#1', wheel: '4-4-0', name: 'Grass Valley', notes: 'Original wood burner built by Baldwin Locomotive Co.' },
  { number: '#2', wheel: '2-6-0', name: 'Nevada', notes: 'Original wood burner built by Baldwin Locomotive Co.' },
  { number: '#3', wheel: '4-4-0', name: '—', notes: 'Purchased in 1877, a twin of #1 but never named' },
  { number: '#4', wheel: '0-6-0', name: '—', notes: 'Purchased in 1899 from Lake Tahoe Railroad' },
  { number: '#5', wheel: '2-6-0', name: '—', notes: 'Purchased in 1889 from Lake Tahoe Railroad' },
  { number: '#6', wheel: '2-6-0', name: '—', notes: 'Purchased in 1915' },
  { number: '#7', wheel: '4-4-0', name: '—', notes: 'Purchased from Southern Pacific' },
  { number: '#8', wheel: '2-8-0', name: '—', notes: 'Came from the Denver & Rio Grande in 1933' },
];
---

<BaseLayout title="Trains | NCNG Model Railroad" description="History of the Nevada County Narrow Gauge Railroad from 1876 to 1942, including the engine roster of Baldwin locomotives and other motive power.">
  <!-- Hero with Engine #8 photo -->
  <section class="relative py-28 md:py-36 text-white overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img 
        src={`${base}/images/engine8-hero.jpg`}
        alt="Engine #8 model on the NCNG layout" 
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-gray-900/85 via-gray-900/50 to-transparent"></div>
    </div>
    <div class="container relative z-10">
      <div class="max-w-3xl">
        <span class="text-sm uppercase tracking-widest text-gray-300 font-medium">The Trains</span>
        <h1 class="text-4xl md:text-5xl font-bold mt-4 mb-6">
          History of the Nevada County Narrow Gauge Railroad
          <span class="text-amber-400">1876–1942</span>
        </h1>
        <p class="text-xl text-gray-200">
          For 66 years the NCNG railroad connected Nevada County's gold mining communities
          to the transcontinental railroad at Colfax.
        </p>
      </div>
    </div>
  </section>

  <!-- History -->
  <section class="py-16 bg-white">
    <div class="container max-w-5xl">
      <SectionHeader eyebrow="Railroad History" title="The Never Come, Never Go" />
      <div class="grid md:grid-cols-5 gap-10 items-start">
        <div class="md:col-span-3 prose prose-lg max-w-none">
          <blockquote class="border-l-4 border-primary pl-6 italic text-gray-700">
            <p>
              The Nevada County Narrow Gauge Railroad was built from the Central Pacific Railroad
              depot in Colfax, C.A. to Grass Valley and Nevada City. Traveling the roads by
              horseback or stagecoach could take the better part of a day and importing the heavy
              timber and mining equipment for the local mines was hard enough when the weather was
              good but the dirt roads were near impassable in the winter. Construction was begun on
              February 11, 1875 and the last spike was driven on May 20, 1876.
            </p>
            <p>
              For the next 66 years, the Nevada County Narrow Gauge railroad (affectionately called
              the "Never Come, Never Go") was the prime method of shipping freight and passengers
              between Nevada County and the Southern (ex Central) Pacific rail connection in Colfax.
            </p>
            <p>
              The first three engines were wood burners, built for the NCNGRR by Baldwin Locomotive
              Co. All the NCNGRR engines were converted to oil by 1916.
            </p>
          </blockquote>
        </div>
        <div class="md:col-span-2 space-y-4">
          <img
            src={`${base}/images/historic-locomotive.jpg`}
            alt="Historic Nevada County Narrow Gauge locomotive"
            class="rounded-lg shadow-lg w-full"
            loading="lazy"
          />
          <img
            src={`${base}/images/historic-engine-full.jpg`}
            alt="Full view of a historic NCNG locomotive"
            class="rounded-lg shadow-lg w-full"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <div class="track-divider"></div>

  <!-- Engine Roster - Card-based -->
  <section class="py-16 bg-cream">
    <div class="container max-w-5xl">
      <SectionHeader eyebrow="Motive Power" title="Engine Roster" />

      <!-- Photo showcase -->
      <div class="grid md:grid-cols-3 gap-4 mb-12">
        <div class="md:col-span-2 aspect-video overflow-hidden rounded-xl shadow-lg">
          <img 
            src={`${base}/images/engine8-freight.jpg`}
            alt="Engine #8 with freight cars on the layout"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="aspect-video md:aspect-auto overflow-hidden rounded-xl shadow-lg">
          <img 
            src={`${base}/images/engine8-yard.jpg`}
            alt="Engine #8 in the railroad yard"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>

      <!-- Engine cards -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {engines.map((engine) => (
          <div class="bg-white rounded-xl shadow-sm p-5 border-l-4 border-primary hover:shadow-md transition-shadow">
            <div class="flex items-baseline justify-between mb-2">
              <span class="text-2xl font-bold text-primary">{engine.number}</span>
              <span class="font-mono text-xs bg-gray-100 px-2 py-1 rounded text-gray-700">{engine.wheel}</span>
            </div>
            {engine.name !== '—' && (
              <p class="italic text-secondary font-medium mb-2">"{engine.name}"</p>
            )}
            <p class="text-gray-600 text-sm leading-relaxed">{engine.notes}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Additional Motive Power -->
  <section class="py-16 bg-white">
    <div class="container max-w-5xl">
      <SectionHeader eyebrow="Other Equipment" title="Gas &amp; Standard Gauge Power" />
      <div class="grid md:grid-cols-5 gap-8 items-start">
        <div class="md:col-span-3 prose prose-lg max-w-none">
          <p class="text-gray-700">
            The NCNGRR had two gas mechanical switchers, #10, a 0-4-0 Plymouth which was acquired
            and wrecked in 1936, and #11, a 0-4-0 Whitcomb. Two standard gauge engines, a two truck
            Heisler and two truck Climax, operated around 1913 on dual gauge track from Colfax to a
            gravel spur on the Bear River.
          </p>
        </div>
        <div class="md:col-span-2">
          <img
            src={`${base}/images/grass-valley-model.jpg`}
            alt="Grass Valley model scene on the layout"
            class="rounded-lg shadow-lg w-full"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Model Photos -->
  <section class="py-16 bg-gray-50">
    <div class="container max-w-5xl">
      <SectionHeader eyebrow="Our Models" title="On the Layout" />
      <div class="grid md:grid-cols-2 gap-6">
        <div class="aspect-video overflow-hidden rounded-xl shadow-lg">
          <img 
            src={`${base}/images/ncng-train-model-1.jpg`}
            alt="Detailed train model on the NCNG layout"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="aspect-video overflow-hidden rounded-xl shadow-lg">
          <img 
            src={`${base}/images/ncng-train-model-2.jpg`}
            alt="Train model detail shot"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

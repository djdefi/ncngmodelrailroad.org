---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import PhotoCard from '../components/PhotoCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { Icon } from 'astro-icon/components';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Nevada County Narrow Gauge Historical Model Railroad" description="An On3 scale historical model railroad display at the Nevada County Fairgrounds, preserving the legacy of the Nevada County Narrow Gauge Railroad (1876–1942). Open during major fairground events." image="/images/engine8-hero.jpg" heroImage={`${base}/images/engine8-hero.jpg`}>
  <!-- Hero Section - Full-bleed with Engine #8 -->
  <section class="relative min-h-[90vh] flex items-end text-white overflow-hidden" aria-labelledby="hero-title">
    <div class="absolute inset-0 z-0">
      <img 
        src={`${base}/images/engine8-hero.jpg`} 
        alt="Engine #8 approaching on the model railroad tracks with switches and scenery" 
        class="w-full h-full object-cover animate-kenburns"
        loading="eager"
        decoding="async"
        fetchpriority="high"
        width={1920}
        height={1080}
      />
      <div class="absolute inset-0 hero-vignette"></div>
    </div>
    <div class="container relative z-10 pb-16 md:pb-24 pt-40">
      <div class="max-w-3xl">
        <span class="hero-kicker inline-block text-xs uppercase font-semibold mb-4 border px-4 py-2 rounded-full">Est. 1986 · Nevada County Fairgrounds · Grass Valley, CA</span>
        <h1 id="hero-title" class="text-4xl md:text-6xl lg:text-7xl font-bold mb-4 text-white leading-[1.1]" style="font-family: 'Archivo Black', serif;">
          Nevada County<br />Narrow Gauge
        </h1>
        <p class="hero-label text-sm uppercase font-medium mb-6">Historical Model Railroad</p>
        <p class="hero-copy text-lg md:text-xl mb-10 leading-relaxed max-w-xl">
          An On3 scale model preserving the railroad that connected Nevada City, Grass Valley, Chicago Park, and Colfax from 1875 to 1942.
        </p>
        <div class="flex flex-wrap gap-4">
          <Button href={`${base}/about`} size="lg">About the Layout</Button>
          <Button href={`${base}/events`} variant="outline" size="lg" class="border-white text-white hover:bg-white hover:text-gray-900">
            Visit Us
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- What is the N.C.N.G.? - Asymmetric layout with real photo -->
  <section class="py-20 md:py-28 bg-white grain-overlay">
    <div class="container">
      <div class="section-shell p-6 md:p-10 lg:p-12 grid lg:grid-cols-5 gap-12 items-center">
        <div class="lg:col-span-3">
          <span class="eyebrow">About the Layout</span>
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mt-3 mb-6 leading-tight">
            A Working Model of the N.C.N.G.
          </h2>
          <p class="text-lg text-gray-600 mb-6 leading-relaxed">
            Built by volunteers since 1986, the layout interprets the Nevada County Narrow Gauge Railroad
            in operating On3 scale. It follows the line through <strong>Nevada City</strong>,
            <strong>Grass Valley</strong>, <strong>Chicago Park</strong>, and <strong>Colfax</strong>,
            with scenes such as Town Talk and the Bear River Bridge.
          </p>
          <div class="flex flex-wrap gap-6 text-sm text-gray-600">
            <span class="flex items-center gap-2">
              <Icon name="solar:verified-check-bold" class="w-5 h-5 text-primary" />
              All Volunteer
            </span>
            <span class="flex items-center gap-2">
              <Icon name="solar:verified-check-bold" class="w-5 h-5 text-primary" />
              Since 1986
            </span>
          </div>
        </div>
        <div class="lg:col-span-2">
          <div class="relative">
            <img 
              src={`${base}/images/about-layout.jpeg`}
              alt="Overview of the N.C.N.G. model railroad layout"
              class="rounded-2xl shadow-2xl w-full"
              loading="lazy"
              decoding="async"
              width={1336}
              height={764}
            />
            <div class="absolute -bottom-4 -left-4 bg-primary text-white px-5 py-3 rounded-full shadow-lg text-sm font-bold">
              22 miles of history · 1875–1942
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="track-divider"></div>

  <!-- Features / What Makes It Special -->
  <section class="py-20 bg-cream">
    <div class="container">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="eyebrow">What You&apos;ll See</span>
        <h2 class="text-3xl md:text-4xl font-bold mt-3 mb-4">Highlights of the Layout</h2>
        <p class="text-gray-600">Trains, local scenes, and operating details that make the line easy to follow.</p>
      </div>
      
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <div class="clean-card hover-lift flex gap-5 p-6">
          <div class="flex-shrink-0 w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center">
            <Icon name="solar:tram-bold" class="w-6 h-6 text-primary" />
          </div>
          <div>
            <h3 class="font-bold text-lg mb-2">Historically Accurate Roster</h3>
            <p class="text-gray-600 text-sm leading-relaxed">The roster includes models based on original N.C.N.G. equipment, from Engine #1 &quot;Grass Valley&quot; to Engine #8 from the Denver &amp; Rio Grande.</p>
          </div>
        </div>

        <div class="clean-card hover-lift flex gap-5 p-6">
          <div class="flex-shrink-0 w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center">
            <Icon name="solar:camera-bold" class="w-6 h-6 text-primary" />
          </div>
          <div>
            <h3 class="font-bold text-lg mb-2">"Train Cam TV"</h3>
            <p class="text-gray-600 text-sm leading-relaxed">On-board cameras let visitors ride along through towns, yards, and bridge scenes from a train-level view.</p>
          </div>
        </div>

        <div class="clean-card hover-lift flex gap-5 p-6">
          <div class="flex-shrink-0 w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center">
            <Icon name="solar:cpu-bold" class="w-6 h-6 text-primary" />
          </div>
          <div>
            <h3 class="font-bold text-lg mb-2">DCC Digital Control</h3>
            <p class="text-gray-600 text-sm leading-relaxed">DCC control lets operators run multiple trains with synchronized lighting, sound, and smooth low-speed movement.</p>
          </div>
        </div>

        <div class="clean-card hover-lift flex gap-5 p-6">
          <div class="flex-shrink-0 w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center">
            <Icon name="solar:history-bold" class="w-6 h-6 text-primary" />
          </div>
          <div>
            <h3 class="font-bold text-lg mb-2">Scenes Along the Line</h3>
            <p class="text-gray-600 text-sm leading-relaxed">The layout follows the line from Colfax to Nevada City, including Chicago Park, Town Talk, and the Bear River Bridge.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Events Section - Invitation-style cards -->
  <section class="py-20 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <SectionHeader eyebrow="Come See Us" title="When We're Open" />
        
        <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-6">
          <div class="clean-card hover-lift p-6">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center">
                <Icon name="solar:calendar-bold" class="w-5 h-5 text-primary" />
              </div>
              <h3 class="font-bold">Fairground Events</h3>
            </div>
            <p class="text-gray-600 text-sm">We're open during major Nevada County Fairgrounds events throughout the year. Check our events page for specific dates.</p>
          </div>

          <div class="clean-card hover-lift p-6">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center">
                <Icon name="solar:settings-bold" class="w-5 h-5 text-primary" />
              </div>
              <h3 class="font-bold">Work Sessions</h3>
            </div>
            <p class="text-gray-600 text-sm">Join us during regular work sessions, usually the first Saturday and third Wednesday from 11 AM to 2 PM, to meet volunteers and see what is underway.</p>
          </div>

          <div class="clean-card hover-lift p-6">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center">
                <Icon name="solar:clock-circle-bold" class="w-5 h-5 text-primary" />
              </div>
              <h3 class="font-bold">Open Houses</h3>
            </div>
            <p class="text-gray-600 text-sm">Special open house events let you see the trains running and talk with our volunteer crew about the railroad's history.</p>
          </div>

          <div class="clean-card hover-lift p-6">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center">
                <Icon name="solar:users-group-rounded-bold" class="w-5 h-5 text-primary" />
              </div>
              <h3 class="font-bold">Group Tours</h3>
            </div>
            <p class="text-gray-600 text-sm">Schools, scout troops, and other groups can arrange private visits. We love sharing this history with young people.</p>
          </div>
        </div>

        <div class="mt-8 text-center">
          <Button href={`${base}/events`}>View Upcoming Events</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Visit CTA - Full width with building exterior photo -->
  <section class="relative py-28 md:py-36 text-white overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img 
        src={`${base}/images/building-exterior.jpg`} 
        alt="N.C.N.G. Historical Model Railroad building at the Nevada County Fairgrounds with Railroad Crossing sign and Historical Exhibit Open sandwich board" 
        class="w-full h-full object-cover"
        loading="lazy"
        decoding="async"
        width={1440}
        height={1920}
      />
      <div class="absolute inset-0 bg-gray-900/60"></div>
    </div>
    <div class="container relative z-10">
      <div class="max-w-2xl">
        <h2 class="text-3xl md:text-5xl font-bold mb-6">Visit the Layout</h2>
        <p class="text-xl text-gray-200 mb-4">
          Located at the Nevada County Fairgrounds in Grass Valley, California.
        </p>
        <address class="text-gray-300 not-italic mb-8 flex items-start gap-3">
          <Icon name="solar:map-point-bold" class="w-6 h-6 text-amber-400 flex-shrink-0 mt-0.5" />
          <span>
            Nevada County Fairgrounds<br />
            Grass Valley, CA<br />
            <span class="text-sm text-gray-200">Free admission during events · Donations appreciated</span>
          </span>
        </address>
        <div class="flex flex-wrap gap-4">
          <Button href={`${base}/events`} size="lg">View Events</Button>
          <Button href={`${base}/contact`} variant="outline" size="lg" class="border-white text-white hover:bg-white hover:text-gray-900">
            Get Directions
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Support Section - Asymmetric, warm appeal -->
  <section class="py-20 bg-white">
    <div class="container">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-5 gap-8">
          <!-- Donate - Takes more space, more prominent -->
          <div class="md:col-span-3 bg-primary text-white rounded-3xl p-8 md:p-10 relative overflow-hidden shadow-2xl">
            <div class="relative z-10">
              <div class="flex items-center gap-3 mb-4">
                <Icon name="solar:heart-bold" class="w-8 h-8 text-amber-300" />
                <span class="text-amber-300 font-semibold uppercase tracking-wider text-sm">Support the Layout</span>
              </div>
              <h2 class="text-2xl md:text-3xl font-bold mb-4">Help Maintain the Layout</h2>
              <p class="text-gray-200 mb-6 leading-relaxed">
                Donations help cover upkeep, repairs, scenery work, rolling stock, wiring,
                and improvements to the building and display.
              </p>
              <Button href={`${base}/donate`} variant="white">
                Support the Layout
              </Button>
            </div>
            <div class="absolute -bottom-8 -right-8 w-32 h-32 bg-white/5 rounded-full"></div>
            <div class="absolute -top-4 -right-12 w-24 h-24 bg-white/5 rounded-full"></div>
          </div>

          <!-- Volunteer - Smaller, complementary -->
          <div class="md:col-span-2 clean-card p-8 md:p-10 flex flex-col justify-between">
            <div>
              <div class="flex items-center gap-3 mb-4">
                <Icon name="solar:users-group-rounded-bold" class="w-7 h-7 text-primary" />
                <span class="text-primary font-semibold uppercase tracking-wider text-sm">Get Involved</span>
              </div>
              <h2 class="text-xl md:text-2xl font-bold mb-4 text-gray-900">Become a Volunteer</h2>
              <p class="text-gray-600 mb-6 text-sm leading-relaxed">
                If you like trains, local history, scenery, wiring, carpentry, or talking with visitors, there&apos;s useful work to do.
              </p>
            </div>
            <Button href={`${base}/volunteer`}>
              Volunteer With Us
            </Button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Note Section -->
  <section class="py-6 bg-gray-100 border-t border-gray-200">
    <div class="container">
      <p class="text-center text-sm text-gray-600">
        <strong>Note:</strong> The N.C.N.G. Historical Model Railroad is a separate 
        organization not affiliated with other museums or groups.
      </p>
    </div>
  </section>
</BaseLayout>

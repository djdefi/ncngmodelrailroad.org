    category: 'Events'
  },
  {
    src: `${base}/images/gallery-img_7239.jpg`,
    alt: 'N.C.N.G. building exterior at the Nevada County Fairgrounds',
    caption: 'N.C.N.G. building at the Nevada County Fairgrounds',
    category: 'Historic'
  },
  {
    src: `${base}/images/gallery-img_7760.jpg`,
    alt: 'Steam locomotive with Christmas wreaths crossing wooden trestle',
    caption: 'Holiday steam train with Christmas wreaths crossing trestle',
    category: 'Layout'
  },
  {
    src: `${base}/images/gallery-img_7761.jpg`,

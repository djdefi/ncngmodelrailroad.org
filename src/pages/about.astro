---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { Icon } from 'astro-icon/components';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const timeline = [
  { year: '1875', event: 'Nevada County Narrow Gauge Railroad begins operations, connecting Colfax to Nevada City and Grass Valley' },
  { year: '1942', event: 'Last train runs; railroad ceases operations after 67 years of service' },
  { year: '1986', event: 'NCNG Historical Model Railroad founded as the "N.C.N.G. Project"' },
  { year: '1990s', event: 'Layout construction begins at Nevada County Fairgrounds' },
  { year: 'Today', event: 'Volunteer team continues to expand and improve the On3 scale layout' },
];
---

<BaseLayout title="About Us | N.C.N.G. Model Railroad" description="Learn about the Nevada County Narrow Gauge Historical Model Railroad, our mission, history, and the volunteers who preserve this piece of California railroad history." heroImage={`${base}/images/about-layout.jpeg`}>
  <!-- Hero with real photo -->
  <section class="relative py-28 md:py-36 text-white overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img 
        src={`${base}/images/about-layout.jpeg`}
        alt="Overview of the N.C.N.G. model railroad layout" 
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
        width={1336}
        height={764}
      />
      <div class="absolute inset-0 bg-gradient-to-r from-gray-900/85 via-gray-900/50 to-transparent"></div>
    </div>
    <div class="container relative z-10">
      <div class="max-w-3xl">
        <span class="text-sm uppercase tracking-widest text-gray-300 font-medium">About Us</span>
        <h1 class="text-4xl md:text-5xl font-bold mt-4 mb-6">
          Preserving Railroad History <span class="text-amber-400">Since 1986</span>
        </h1>
        <p class="text-xl text-gray-200">
          The N.C.N.G. Historical Model Railroad is a 501(c)(3) nonprofit, all-volunteer 
          organization dedicated to preserving the memory of the Nevada County Narrow Gauge Railroad.
        </p>
      </div>
    </div>
  </section>

  <!-- Mission with photo -->
  <section class="py-16 bg-white">
    <div class="container max-w-5xl">
      <div class="grid md:grid-cols-5 gap-10 items-center">
        <div class="md:col-span-3">
          <SectionHeader eyebrow="Our Mission" title="Keeping History Alive" />
          <div class="prose prose-lg max-w-none">
            <p>
              Our mission is to educate the public about the historic Nevada County Narrow Gauge Railroad 
              through our meticulously crafted On3 scale model railroad. The original N.C.N.G. railroad operated 
              from 1875 to 1942, serving the gold mining communities of Nevada City, Grass Valley, and 
              connecting them to the transcontinental railroad at Colfax.
            </p>
            <p>
              Through accurate modeling of the locomotives, rolling stock, structures, and scenery, 
              we bring this important piece of California history to life for new generations.
            </p>
          </div>
        </div>
        <div class="md:col-span-2">
          <img 
            src={`${base}/images/grass-valley-model.jpg`}
            alt="Grass Valley model scene on the layout"
            class="rounded-xl shadow-2xl w-full"
            loading="lazy"
            width={640}
            height={389}
          />
        </div>
      </div>
    </div>
  </section>

  <div class="track-divider"></div>

  <!-- Timeline -->
  <section class="py-16 bg-cream">
    <div class="container max-w-4xl">
      <SectionHeader eyebrow="Our History" title="A Timeline of Preservation" />
      <div class="space-y-6">
        {timeline.map((item, index) => (
          <div class="flex gap-4 items-start">
            <div class="flex-shrink-0 w-20 text-right">
              <span class="font-bold text-primary">{item.year}</span>
            </div>
            <div class="flex-shrink-0 w-4 relative">
              <div class="w-4 h-4 bg-primary rounded-full"></div>
              {index < timeline.length - 1 && (
                <div class="absolute top-4 left-1/2 -translate-x-1/2 w-0.5 h-12 bg-gray-300"></div>
              )}
            </div>
            <div class="flex-grow pb-8">
              <p class="text-gray-700">{item.event}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- The Model - with photos -->
  <section class="py-16 bg-white">
    <div class="container max-w-5xl">
      <SectionHeader eyebrow="The Layout" title="On3 Scale Precision" />
      <div class="grid md:grid-cols-2 gap-10">
        <div>
          <h3 class="text-xl font-bold mb-3">What is On3?</h3>
          <p class="text-gray-600 mb-6">
            "On3" refers to O scale (1:48 ratio) with 3-foot narrow gauge track. This scale 
            accurately represents the narrow gauge equipment used by the original N.C.N.G. railroad.
          </p>
          <h3 class="text-xl font-bold mb-3">Features</h3>
          <ul class="space-y-3 text-gray-600">
            <li class="flex items-center gap-3">
              <Icon name="solar:cpu-bold" class="w-5 h-5 text-primary flex-shrink-0" />
              DCC digital control system
            </li>
            <li class="flex items-center gap-3">
              <Icon name="solar:tram-bold" class="w-5 h-5 text-primary flex-shrink-0" />
              Historically accurate locomotives
            </li>
            <li class="flex items-center gap-3">
              <Icon name="solar:verified-check-bold" class="w-5 h-5 text-primary flex-shrink-0" />
              Period-correct rolling stock
            </li>
            <li class="flex items-center gap-3">
              <Icon name="solar:camera-bold" class="w-5 h-5 text-primary flex-shrink-0" />
              "Train Cam TV" on-board cameras
            </li>
            <li class="flex items-center gap-3">
              <Icon name="solar:history-bold" class="w-5 h-5 text-primary flex-shrink-0" />
              Detailed scenery and structures
            </li>
          </ul>
        </div>
        <div class="space-y-4">
          <img 
            src={`${base}/images/ncng-train-model-1.jpg`}
            alt="Detailed train model on the N.C.N.G. layout"
            class="rounded-xl shadow-lg w-full"
            loading="lazy"
            width={550}
            height={320}
          />
          <div class="grid grid-cols-2 gap-4">
            <img 
              src={`${base}/images/ncng-train-model-2.jpg`}
              alt="Close-up of a model train on the N.C.N.G. layout with detailed scenery"
              class="rounded-lg shadow-md w-full aspect-square object-cover"
              loading="lazy"
              width={550}
              height={358}
            />
            <img 
              src={`${base}/images/engine8-yard.jpg`}
              alt="Engine #8 in the yard"
              class="rounded-lg shadow-md w-full aspect-square object-cover"
              loading="lazy"
              width={1920}
              height={1080}
            />
          </div>
        </div>
      </div>

      <div class="mt-12">
        <h3 class="text-xl font-bold mb-3">Towns &amp; Scenes</h3>
        <p class="text-gray-600 mb-4">
          The layout recreates the three major towns along the original line:
        </p>
        <div class="grid sm:grid-cols-3 gap-4">
          <div class="bg-cream p-5 rounded-xl">
            <h4 class="font-bold text-primary">Nevada City</h4>
            <p class="text-gray-600 text-sm">Northern terminus of the line</p>
          </div>
          <div class="bg-cream p-5 rounded-xl">
            <h4 class="font-bold text-primary">Grass Valley</h4>
            <p class="text-gray-600 text-sm">Heart of the mining district</p>
          </div>
          <div class="bg-cream p-5 rounded-xl">
            <h4 class="font-bold text-primary">Colfax</h4>
            <p class="text-gray-600 text-sm">Connection to SP mainline</p>
          </div>
        </div>
        <p class="text-gray-600 mt-4">
          Plus scenic highlights like the Bear River Bridge and gold mining operations.
        </p>
      </div>
    </div>
  </section>

  <!-- Nonprofit Status -->
  <section class="relative py-20 text-white overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img 
        src={`${base}/images/engine8-freight.jpg`}
        alt="Engine #8 with freight cars"
        class="w-full h-full object-cover"
        loading="lazy"
        width={1920}
        height={1080}
      />
      <div class="absolute inset-0 bg-primary/85"></div>
    </div>
    <div class="container relative z-10 text-center max-w-2xl">
      <Icon name="solar:verified-check-bold" class="w-12 h-12 text-amber-300 mx-auto mb-4" />
      <h2 class="text-3xl font-bold mb-4">501(c)(3) Nonprofit Organization</h2>
      <p class="text-xl text-gray-200 mb-6">
        The N.C.N.G. Historical Model Railroad is a federally recognized 501(c)(3) tax-exempt 
        organization. Your donations are tax-deductible.
      </p>
      <p class="text-sm text-gray-300 mb-8">
        <strong>Note:</strong> We are a separate nonprofit organization not affiliated with 
        other museums or groups.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <Button href={`${base}/donate`} variant="white">Support Our Mission</Button>
        <Button href={`${base}/volunteer`} variant="outline" class="border-white text-white hover:bg-white hover:text-primary">
          Join Our Team
        </Button>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="py-16 bg-white">
    <div class="container max-w-4xl">
      <div class="grid md:grid-cols-2 gap-8">
        <div>
          <SectionHeader eyebrow="Location" title="Visit Us" />
          <address class="text-gray-600 not-italic mb-4 flex items-start gap-3">
            <Icon name="solar:map-point-bold" class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" />
            <span>Nevada County Fairgrounds<br />Grass Valley, California</span>
          </address>
          <p class="text-gray-600">
            Open during major fairground events, special open houses, and by special arrangement.
          </p>
          <Button href={`${base}/events`} class="mt-4">View Events</Button>
        </div>
        <div>
          <SectionHeader eyebrow="Contact" title="Get in Touch" />
          <p class="text-gray-600 mb-4">
            For inquiries about visiting, volunteering, or group tours, please contact us:
          </p>
          <div class="flex items-center gap-2">
            <Icon name="solar:letter-bold" class="w-5 h-5 text-primary" />
            <a href="mailto:info@ncngmodelrailroad.org" class="text-primary hover:underline font-medium">
              info@ncngmodelrailroad.org
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

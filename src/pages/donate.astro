---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { Icon } from 'astro-icon/components';
import { organization } from '../config/organization';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const supportWays = [
  { icon: 'solar:settings-bold', title: 'Maintenance', desc: 'Help keep our locomotives and rolling stock in operating condition' },
  { icon: 'solar:buildings-2-bold', title: 'Layout Building', desc: 'Assist with building new scenes and improving the layout' },
  { icon: 'solar:lightbulb-bolt-bold', title: 'Technical Skills', desc: 'DCC systems, lighting, electronics, and wiring' },
  { icon: 'solar:book-bold', title: 'Education', desc: 'Help develop educational materials and guide visitors' },
  { icon: 'solar:buildings-bold', title: 'Facility Care', desc: 'Help maintain our building at the Nevada County Fairgrounds' },
];
---

<BaseLayout title="Support Us | N.C.N.G. Model Railroad" description="Support the N.C.N.G. Historical Model Railroad with volunteer time, donated materials, or financial contributions.">
  <!-- Hero -->
  <section class="py-20 bg-primary text-white">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-6">
          Support the Layout
        </h1>
        <p class="text-xl text-gray-200 mb-4">
          Volunteer time, donated materials, and financial support help keep the layout running
          and open to the public.
        </p>
        <div class="inline-flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full text-sm">
          <Icon name="solar:users-group-rounded-bold" class="w-5 h-5" />
          <span>All-Volunteer Organization</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Support Options -->
  <section class="py-16 bg-white">
    <div class="container max-w-4xl">
      <h2 class="text-3xl font-bold text-center mb-12">Ways to Help</h2>

      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <!-- Volunteer -->
        <div class="bg-gray-50 p-8 rounded-2xl border border-gray-200">
          <div class="mb-4"><Icon name="solar:users-group-rounded-bold" class="w-10 h-10 text-primary" /></div>
          <h3 class="text-xl font-bold mb-3">Volunteer Your Time</h3>
          <p class="text-gray-600 mb-6">
            We always need people who can help operate trains, work on scenery, maintain equipment,
            or talk with visitors. No prior model railroad experience is required.
          </p>
          <Button href={`${base}/volunteer`} variant="primary" class="w-full text-center">
            Learn About Volunteering
          </Button>
        </div>

        <!-- Donate Materials -->
        <div class="bg-gray-50 p-8 rounded-2xl border border-gray-200">
          <div class="mb-4"><Icon name="solar:tram-bold" class="w-10 h-10 text-primary" /></div>
          <h3 class="text-xl font-bold mb-3">Donate Equipment & Materials</h3>
          <p class="text-gray-600 mb-4">
            We're always happy to hear from folks who have model railroad equipment
            looking for a good home. We mostly work with On3 scale, DCC systems,
            tools, and historical railroad items.
          </p>
          <p class="text-gray-600 mb-6 text-sm">
            We do have limited space, so please reach out before dropping anything off.
            Feel free to send along a few photos and we can go from there!
          </p>
          <a href={`mailto:${organization.contact.email}`} class="btn-primary w-full py-3 text-center block">
            Send Us a Message
          </a>
        </div>
      </div>

      <!-- Monetary donations notice -->
      <div class="bg-amber-50 p-8 rounded-2xl border border-amber-200" aria-labelledby="monetary-donations-title">
        <div class="flex flex-col gap-5 md:flex-row md:items-start">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary/10">
            <Icon name="solar:heart-bold" class="w-6 h-6 text-primary" />
          </div>
          <div>
            <h3 id="monetary-donations-title" class="text-xl font-bold mb-3 text-gray-900">Monetary Donations</h3>
            <p class="text-gray-800 mb-3">
              We&apos;re updating our donation processing, so online donations are temporarily unavailable.
            </p>
            <p class="text-gray-700 mb-5">
              To make a financial contribution, email{' '}
              <a href={`mailto:${organization.contact.email}`} class="text-primary hover:underline font-semibold">
                {organization.contact.email}
              </a>
              {' '}and we&apos;ll coordinate directly.
            </p>
            <a href={`mailto:${organization.contact.email}`} class="btn-primary">
              Email Us About Donations
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How Support Helps -->
  <section class="py-16 bg-gray-50">
    <div class="container max-w-4xl">
      <h2 class="text-3xl font-bold text-center mb-4">Where Your Support Goes</h2>
        <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
          Support goes straight to maintenance, scenery, electrical work, rolling stock, and building upkeep.
        </p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {supportWays.map(way => (
          <div class="bg-white p-6 rounded-xl shadow-sm">
            <div class="mb-3"><Icon name={way.icon} class="w-8 h-8 text-primary" /></div>
            <h3 class="font-bold mb-2">{way.title}</h3>
            <p class="text-gray-600 text-sm">{way.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-gray-900 text-white">
    <div class="container text-center max-w-2xl">
      <h2 class="text-3xl font-bold mb-4">Want to Help?</h2>
      <p class="text-gray-300 mb-8">
        Whether you can volunteer, donate materials, or make a financial contribution,
        it all helps keep the layout operating.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <Button href={`${base}/volunteer`} variant="outline" class="border-white text-white hover:bg-white hover:text-gray-900">
          Volunteer With Us
        </Button>
        <Button href={`${base}/about`} variant="outline" class="border-white text-white hover:bg-white hover:text-gray-900">
          Learn More About Us
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>

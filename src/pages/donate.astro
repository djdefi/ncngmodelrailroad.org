---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { Icon } from 'astro-icon/components';
import { organization } from '../config/organization';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const supportWays = [
  { icon: 'solar:settings-bold', title: 'Maintenance', desc: 'Help keep our locomotives and rolling stock in operating condition' },
  { icon: 'solar:buildings-2-bold', title: 'Layout Building', desc: 'Assist with building new scenes and improving the layout' },
  { icon: 'solar:lightbulb-bolt-bold', title: 'Technical Skills', desc: 'DCC systems, lighting, electronics, and wiring' },
  { icon: 'solar:book-bold', title: 'Education', desc: 'Help develop educational materials and guide visitors' },
  { icon: 'solar:buildings-bold', title: 'Facility Care', desc: 'Help maintain our building at the Nevada County Fairgrounds' },
];
---

<BaseLayout title="Support Us | N.C.N.G. Model Railroad" description="Support the Nevada County Narrow Gauge Historical Model Railroad. Volunteer your time or donate materials to help preserve California railroad history.">
  <!-- Hero -->
  <section class="py-20 bg-primary text-white">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-6">
          Support Railroad History
        </h1>
        <p class="text-xl text-gray-200 mb-4">
          Help us preserve and share the story of the
          Nevada County Narrow Gauge Railroad with future generations.
        </p>
        <div class="inline-flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full text-sm">
          <Icon name="solar:users-group-rounded-bold" class="w-5 h-5" />
          <span>All-Volunteer Organization</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Support Options -->
  <section class="py-16 bg-white">
    <div class="container max-w-4xl">
      <h2 class="text-3xl font-bold text-center mb-12">Ways to Help</h2>

      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <!-- Volunteer -->
        <div class="bg-gray-50 p-8 rounded-2xl border border-gray-200">
          <div class="mb-4"><Icon name="solar:users-group-rounded-bold" class="w-10 h-10 text-primary" /></div>
          <h3 class="text-xl font-bold mb-3">Volunteer Your Time</h3>
          <p class="text-gray-600 mb-6">
            We're an all-volunteer organization and always looking for helping hands.
            No model railroad experience necessary—just enthusiasm for history and trains!
          </p>
          <Button href={`${base}/volunteer`} variant="primary" class="w-full text-center">
            Learn About Volunteering
          </Button>
        </div>

        <!-- Donate Materials -->
        <div class="bg-gray-50 p-8 rounded-2xl border border-gray-200">
          <div class="mb-4"><Icon name="solar:tram-bold" class="w-10 h-10 text-primary" /></div>
          <h3 class="text-xl font-bold mb-3">Donate Materials</h3>
          <p class="text-gray-600 mb-4">
            We selectively accept donations of quality model railroad equipment
            that fits our layout — primarily On3, HO scale, and DCC systems.
            We also welcome historical railroad artifacts and specialized tools.
          </p>
          <p class="text-gray-600 mb-6 text-sm">
            Due to limited space, please <strong>contact us first</strong> before bringing items.
            We're looking for specific equipment that aligns with our N.C.N.G. historical focus
            — not general estate cleanouts.
          </p>
          <a href={`mailto:${organization.contact.email}`} class="btn-primary w-full py-3 text-center block">
            Contact Us First
          </a>
        </div>
      </div>

      <!-- Monetary donations notice -->
      <div class="bg-blue-50 p-8 rounded-2xl border border-blue-200 text-center">
        <div class="mb-4"><Icon name="solar:info-circle-bold" class="w-10 h-10 text-blue-600" /></div>
        <h3 class="text-xl font-bold mb-3">Monetary Donations</h3>
        <p class="text-gray-700 mb-2">
          We are currently updating our donation processing. Online donations are temporarily unavailable.
        </p>
        <p class="text-gray-700">
          If you'd like to make a financial contribution, please contact us at
          <a href={`mailto:${organization.contact.email}`} class="text-primary hover:underline font-medium">
            {organization.contact.email}
          </a>
          and we'll coordinate directly.
        </p>
      </div>
    </div>
  </section>

  <!-- How Support Helps -->
  <section class="py-16 bg-gray-50">
    <div class="container max-w-4xl">
      <h2 class="text-3xl font-bold text-center mb-4">Where Your Support Goes</h2>
      <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
        As an all-volunteer organization, every bit of help goes directly to
        preserving and improving the layout.
      </p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {supportWays.map(way => (
          <div class="bg-white p-6 rounded-xl shadow-sm">
            <div class="mb-3"><Icon name={way.icon} class="w-8 h-8 text-primary" /></div>
            <h3 class="font-bold mb-2">{way.title}</h3>
            <p class="text-gray-600 text-sm">{way.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-gray-900 text-white">
    <div class="container text-center max-w-2xl">
      <h2 class="text-3xl font-bold mb-4">Every Bit of Help Makes a Difference</h2>
      <p class="text-gray-300 mb-8">
        Whether you can spare an afternoon or a box of old railroad memorabilia,
        your support helps us continue our mission of preserving Nevada County railroad history.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <Button href={`${base}/volunteer`} variant="outline" class="border-white text-white hover:bg-white hover:text-gray-900">
          Volunteer With Us
        </Button>
        <Button href={`${base}/about`} variant="outline" class="border-white text-white hover:bg-white hover:text-gray-900">
          Learn More About Us
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';

const opportunities = [
  { emoji: '🚂', title: 'Train Operations', desc: 'Run trains during events and open houses' },
  { emoji: '🔧', title: 'Maintenance & Construction', desc: 'Help build and maintain the layout' },
  { emoji: '🎨', title: 'Scenery & Detailing', desc: 'Create realistic landscapes and structures' },
  { emoji: '📸', title: 'Photography & Documentation', desc: 'Document our work and history' },
  { emoji: '👋', title: 'Visitor Engagement', desc: 'Welcome guests and share railroad history' },
];

const interests = [
  { value: 'operations', label: 'Train Operations' },
  { value: 'maintenance', label: 'Maintenance & Construction' },
  { value: 'scenery', label: 'Scenery & Detailing' },
  { value: 'photography', label: 'Photography' },
  { value: 'visitors', label: 'Visitor Engagement' },
];
---

<BaseLayout title="Volunteer | NCNG Model Railroad" description="Join our volunteer team and help preserve Nevada County railroad history">
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-2xl">
      <h1 class="text-4xl font-display text-primary mb-4">Become a Volunteer</h1>
      <p class="text-xl text-gray-600 mb-8">
        Join our dedicated team of volunteers who keep the memory of the Nevada County Narrow Gauge Railroad alive.
      </p>

      <div class="bg-cream p-6 rounded-lg mb-8">
        <h2 class="text-xl font-semibold mb-4">Volunteer Opportunities</h2>
        <ul class="space-y-3">
          {opportunities.map(opp => (
            <li class="flex items-start gap-3">
              <span class="text-primary text-xl">{opp.emoji}</span>
              <div>
                <strong>{opp.title}</strong>
                <p class="text-gray-600 text-sm">{opp.desc}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Detailed Info Sections -->
      <div class="space-y-8 mb-8">
        <div class="bg-amber-50 border-l-4 border-primary p-6 rounded-r-lg">
          <h2 class="text-2xl font-bold text-primary mb-3">Welcome New Members!</h2>
          <p class="text-gray-700 font-semibold mb-2">New Members, Junior Members, Docents, School Teachers Welcome!</p>
          <p class="text-gray-600">Become a participant of history, and help out your community, and help share the knowledge of Nevada County's rich railroad history with others! The N.C.N.G. Historical Model Railroad – not a club – has things to do in all shapes and sizes! – from improving, repair and maintenance to the layout and building to telling the public railroad history stories at our open houses!</p>
        </div>

        <div class="bg-white border border-gray-200 p-6 rounded-lg">
          <h3 class="text-xl font-bold text-primary mb-3">📅 Work Sessions</h3>
          <p class="text-gray-700 font-medium mb-2">First Saturday and Third Wednesday of the month — Noon to 1pm</p>
          <p class="text-gray-600 mb-3">Come see us at the layout! – First Saturday and the Third Wednesday of the month – Noon to 1pm – if you are interested in model railroading, or the historical railroad history of Nevada County, we have something for you!</p>
          <p class="text-sm text-gray-500 italic">Special note – these work sessions are generally canceled whenever there is a paid admission event at the fairgrounds. There may be a parking fee at some free events held at the fairgrounds. Otherwise, park at Gate 1 and enter – the Historical Model Railroad is to the left.</p>
        </div>

        <div class="bg-white border border-gray-200 p-6 rounded-lg">
          <h3 class="text-xl font-bold text-primary mb-3">🎙️ Docents Needed</h3>
          <p class="text-gray-600">Do you like to share with others the history of our county? Are you good at storytelling or talking with the public? During our open houses, docents are needed to help explain to the public the history of the Nevada County Narrow Gauge railroad. No need to bother with modelbuilding – just share the joy of knowing the county's railroad history! And we have the information, even if you don't! So if history is your passion, then become a N.C.N.G. Historical Model Railroad docent.</p>
        </div>

        <div class="bg-white border border-gray-200 p-6 rounded-lg">
          <h3 class="text-xl font-bold text-primary mb-3">👦 Junior Members (Ages 12-18)</h3>
          <p class="text-gray-600">Junior Members Welcomed – A special category for Junior Members (12-18 years, with an accompanying adult member) is also available. Junior members are encouraged to learn the ins and outs of model railroading, as well as the history of the Nevada County Narrow Gauge railroad. A family adult will need to participate with the junior member.</p>
        </div>

        <div class="bg-white border border-gray-200 p-6 rounded-lg">
          <h3 class="text-xl font-bold text-primary mb-3">🏫 School Teachers</h3>
          <p class="text-gray-600">Attention School Teachers! Are you teaching Nevada County history, or transportation history, and would like to give your students a unique experience revisiting the Nevada County Narrow Gauge railroad. Our museum quality model is bound to inspire the imagination of your students. Contact us to make arrangements for your class's own special tour. Tours are generally scheduled well in advance.</p>
        </div>
      </div>

      <form 
        name="volunteer" 
        method="POST" 
        action="https://formspree.io/f/YOUR_FORM_ID"
        class="space-y-6 bg-white border border-gray-200 p-6 rounded-lg"
      >
        <!-- Get free form endpoint at https://formspree.io (50 submissions/month free) -->
        <!-- Or use: action="mailto:info@ncngmodelrailroad.org" for simple email -->
        
        <div>
          <label for="name" class="block text-sm font-medium text-gray-700 mb-1">
            Full Name *
          </label>
          <input 
            type="text" 
            id="name" 
            name="name" 
            required
            class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-primary focus:border-primary"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
            Email Address *
          </label>
          <input 
            type="email" 
            id="email" 
            name="email" 
            required
            class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-primary focus:border-primary"
          />
        </div>

        <div>
          <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">
            Phone (optional)
          </label>
          <input 
            type="tel" 
            id="phone" 
            name="phone"
            class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-primary focus:border-primary"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">
            Areas of Interest
          </label>
          <div class="space-y-2">
            {interests.map(int => (
              <label class="flex items-center gap-2">
                <input type="checkbox" name="interests" value={int.value} class="rounded text-primary" />
                <span>{int.label}</span>
              </label>
            ))}
          </div>
        </div>

        <div>
          <label for="experience" class="block text-sm font-medium text-gray-700 mb-1">
            Tell us about yourself
          </label>
          <textarea 
            id="experience" 
            name="experience" 
            rows="4"
            placeholder="Any model railroad experience? What interests you about NCNG history?"
            class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-primary focus:border-primary"
          ></textarea>
        </div>

        <Button type="submit" class="w-full py-3">Submit Volunteer Application</Button>
        
        <p class="text-sm text-gray-500 text-center">
          We'll reach out within a week to discuss opportunities.
        </p>
      </form>
    </div>
  </section>
</BaseLayout>
